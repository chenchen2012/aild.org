---
import '../styles/global.css';
import pageLastmod from '../data/page-lastmod.json';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  active?: string;
  lang?: string;
  robots?: string;
  showUpdatedStamp?: boolean;
  alternates?: { hreflang: string; href: string }[];
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  ogType?: string;
  ogImage?: string;
}

const {
  title,
  description = 'AILD helps executives, transformation leaders, and governance leaders make practical decisions about AI governance, readiness, board oversight, and operating cadence.',
  canonical,
  active = '',
  lang = 'en',
  robots = 'index,follow',
  showUpdatedStamp = true,
  alternates = [],
  jsonLd,
  ogType = 'website',
  ogImage = 'https://aild.org/og-default.jpg',
} = Astro.props;

const pathname = Astro.url.pathname;
const isZh = pathname === '/zh' || pathname.startsWith('/zh/');
const isLanguageLanding =
  pathname === '/en' || pathname === '/en/' || pathname === '/es' || pathname === '/es/';
const makeLocalizedPath = (basePath: string) => {
  if (!isZh) return basePath;
  if (basePath === '/') return '/zh/';
  return `/zh${basePath}`;
};
const englishDefaultPath =
  pathname === '/en' || pathname === '/en/' ? '/' : isZh ? pathname.replace(/^\/zh/, '') || '/' : pathname;
const chineseDefaultPath =
  isLanguageLanding ? '/zh/' : isZh ? pathname : pathname === '/' ? '/zh/' : `/zh${pathname}`;
const enPath = englishDefaultPath;
const zhPath = chineseDefaultPath;
const brandFullName = 'AI Lab for Decisionmakers';
const brandHref = isZh ? '/zh/' : '/';
const siteUrl = 'https://aild.org';
const priorityPathLabel = isZh ? '从这里开始' : 'Start Here';
const normalizedPath = pathname.endsWith('/') ? pathname : `${pathname}/`;
const lastmodMap = pageLastmod as Record<string, string>;
const visibleLastmod = lastmodMap[normalizedPath];
const updatedLabel = isZh ? '更新于' : 'Updated';
const formattedLastmod = visibleLastmod
  ? new Date(visibleLastmod).toLocaleDateString(isZh ? 'zh-CN' : 'en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : '';
const footerLinks = [
  { href: '/board-readiness/', en: 'Board Readiness', zh: '董事会准备' },
  { href: '/ai-governance/', en: 'AI Governance', zh: 'AI治理' },
  { href: '/executive-reporting/', en: 'Executive Reporting', zh: '高管汇报' },
  { href: '/operating-rhythm/', en: 'Operating Rhythm', zh: '运营节奏' },
  { href: '/advisory/', en: 'Advisory', zh: '咨询服务' },
  { href: '/author/', en: 'Author', zh: '作者说明' },
  { href: '/editorial-standards/', en: 'Editorial Standards', zh: '编辑标准' },
  { href: '/weekly-brief/', en: 'Weekly Brief', zh: '每周简报' },
];
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID?.trim() || 'G-WKLPXSSB6Z';
const autoAlternates =
  alternates.length > 0
    ? alternates
    : isLanguageLanding
      ? []
      : [
          { hreflang: 'en', href: `${siteUrl}${enPath}` },
          { hreflang: 'zh-CN', href: `${siteUrl}${zhPath}` },
          { hreflang: 'zh', href: `${siteUrl}${zhPath}` },
          { hreflang: 'x-default', href: `${siteUrl}${enPath}` },
        ];

const baseJsonLd: Array<Record<string, unknown>> = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'AI Lab for Decisionmakers',
    alternateName: 'AILD',
    url: siteUrl,
    logo: `${siteUrl}/favicon.svg`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'AI Lab for Decisionmakers',
    url: siteUrl,
    inLanguage: ['en', 'zh-CN'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: canonical ?? `${siteUrl}${pathname}`,
    inLanguage: lang,
  },
];

const pageJsonLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const allJsonLd = [...baseJsonLd, ...pageJsonLd];

const nav = [
  { href: '/board-readiness/', en: 'Board Readiness', zh: '董事会准备', key: 'board-readiness' },
  { href: '/ai-governance/', en: 'AI Governance', zh: 'AI治理', key: 'ai-governance' },
  { href: '/90-day-rollout/', en: '90-Day Rollout', zh: '90天落地', key: '90-day-rollout' },
  { href: '/executive-reporting/', en: 'Executive Reporting', zh: '高管汇报', key: 'executive-reporting' },
  { href: '/operating-rhythm/', en: 'Operating Rhythm', zh: '运营节奏', key: 'operating-rhythm' },
  { href: '/advisory/', en: 'Executive Advisory', zh: '高管咨询', key: 'advisory' },
  { href: '/about/', en: 'About', zh: '关于', key: 'about' },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {canonical && <link rel="canonical" href={canonical} />}
    {autoAlternates.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <meta property="og:site_name" content="AILD" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="AILD social preview" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <script type="application/ld+json" set:html={JSON.stringify(allJsonLd.length === 1 ? allJsonLd[0] : allJsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <div class="wrapper header-row">
        <a class="brand" href={brandHref} aria-label={`AILD | ${brandFullName}`}>
          <span class="brand-mark">AILD</span>
          <span class="brand-divider" aria-hidden="true">|</span>
          <span class="brand-full">{brandFullName}</span>
        </a>
        <nav class="nav-links" aria-label="Main navigation">
          {
            nav.map((item) => (
              <a class={active === item.key ? 'active' : ''} href={makeLocalizedPath(item.href)}>
                {isZh ? item.zh : item.en}
              </a>
            ))
          }
        </nav>
        <div class="header-actions">
          <a class="header-cta" href={makeLocalizedPath('/#priority-paths')}>{priorityPathLabel}</a>
          <div class="lang-switch" aria-label="Language switcher">
            <a class={!isZh ? 'active' : ''} href={enPath}>EN</a>
            <a class={isZh ? 'active' : ''} href={zhPath}>中文</a>
          </div>
        </div>
      </div>
    </header>
    <main class="page wrapper">
      {
        showUpdatedStamp && formattedLastmod && (
          <p class="page-updated-stamp">
            <span>{updatedLabel}</span>
            <time datetime={visibleLastmod}>{formattedLastmod}</time>
          </p>
        )
      }
      <slot />
    </main>
    <footer class="footer">
      <div class="wrapper footer-inner">
        <div class="footer-brand">
          <span>© {new Date().getFullYear()} AILD.org | AI Lab for Decisionmakers</span>
          <span>{isZh ? '面向管理层的AI治理、董事会监督与运营节奏平台' : 'Executive AI governance, board oversight, rollout planning, and operating rhythm platform'}</span>
        </div>
        <div class="footer-links">
          {footerLinks.map((item) => (
            <a href={makeLocalizedPath(item.href)}>{isZh ? item.zh : item.en}</a>
          ))}
        </div>
      </div>
    </footer>
    {
      gaMeasurementId && (
        <script is:inline define:vars={{ gaMeasurementId }}>
          (() => {
            const GA_ID = gaMeasurementId;
            const LOAD_DELAY_MS = 8000;
            const POST_LOAD_DELAY_MS = 1200;
            const IDLE_TIMEOUT_MS = 12000;

            if (typeof window === 'undefined' || typeof document === 'undefined' || !GA_ID) return;
            if (window.__aildGaLazyInitialized) return;
            window.__aildGaLazyInitialized = true;

            window.dataLayer = window.dataLayer || [];
            if (typeof window.gtag !== 'function') {
              window.gtag = function gtag() {
                window.dataLayer.push(arguments);
              };
            }

            if (!window.__aildGaConfigured) {
              window.__aildGaConfigured = true;
              window.gtag('js', new Date());
              window.gtag('config', GA_ID, {
                anonymize_ip: true,
              });
            }

            let started = false;

            const loadAnalytics = () => {
              if (started) return;
              started = true;

              const script = document.createElement('script');
              script.src = `https://www.googletagmanager.com/gtag/js?id=${GA_ID}`;
              script.async = true;
              document.head.appendChild(script);
            };

            const scheduleDeferredLoad = () => {
              window.setTimeout(() => {
                if ('requestIdleCallback' in window) {
                  window.requestIdleCallback(() => {
                    loadAnalytics();
                  }, { timeout: IDLE_TIMEOUT_MS });
                  return;
                }
                loadAnalytics();
              }, LOAD_DELAY_MS);
            };

            if (document.readyState === 'complete') {
              window.setTimeout(scheduleDeferredLoad, POST_LOAD_DELAY_MS);
            } else {
              window.addEventListener('load', () => {
                window.setTimeout(scheduleDeferredLoad, POST_LOAD_DELAY_MS);
              }, { once: true });
            }

            ['pointerdown', 'keydown', 'touchstart', 'scroll'].forEach((eventName) => {
              window.addEventListener(eventName, loadAnalytics, { once: true, passive: true });
            });
          })();
        </script>
      )
    }
  </body>
</html>
