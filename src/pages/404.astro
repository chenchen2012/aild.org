---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | AILD"
  description="The page you requested could not be found on AILD."
  robots="noindex,follow"
>
  <section class="section">
    <p class="eyebrow">404</p>
    <h1>Page not found</h1>
    <p class="lead">
      The page you requested does not exist or may have moved. Start from the homepage or continue into the main
      knowledge sections below.
    </p>
    <div class="stack">
      <a class="btn btn-primary" href="/">Go to homepage</a>
      <a class="btn btn-secondary" href="/learn/">Browse guides</a>
    </div>
  </section>
</Layout>
