---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allDocs = await getCollection('docs');
const docs = allDocs
  .filter((doc) => !doc.data.tags.includes('weekly-brief'))
  .sort((a, b) => new Date(b.data.updatedDate ?? b.data.pubDate).getTime() - new Date(a.data.updatedDate ?? a.data.pubDate).getTime());
const tags = Array.from(new Set(docs.flatMap((d) => d.data.tags))).sort();

const flagshipSlugs = [
  'ai-leadership-maturity-model',
  'ai-decision-intelligence-stack-executives',
  'trust-vs-override-framework',
  'board-ai-governance-briefing',
  'executive-decision-memo-template',
  'ai-signal-to-decision-operating-rhythm',
];

const implementationSlugs = [
  'ai-augmented-executive-workflow',
  'ai-assisted-strategic-review-playbook',
  'governance-lite-implementation',
  'decision-quality-scorecard-for-ai-teams',
  'ai-roi-dashboard-and-metrics',
  '90-day-ai-adoption-roadmap',
];

const flagshipDocs = flagshipSlugs
  .map((slug) => docs.find((doc) => doc.slug === slug))
  .filter(Boolean);

const implementationDocs = implementationSlugs
  .map((slug) => docs.find((doc) => doc.slug === slug))
  .filter(Boolean);

const quickStarts = [
  {
    title: 'AI governance framework',
    desc: 'Start here if your real question is how to govern AI use without stalling adoption.',
    links: [
      { href: '/learn/trust-vs-override-framework/', label: 'Trust vs Override Framework' },
      { href: '/learn/board-ai-governance-briefing/', label: 'Board AI Governance Briefing' },
      { href: '/learn/governance-lite-implementation/', label: 'Governance implementation guide' },
    ],
  },
  {
    title: 'AI readiness checklist',
    desc: 'Use this path when you need to assess leadership readiness before a broader rollout.',
    links: [
      { href: '/ai-leadership-readiness-checklist/', label: 'Leadership Readiness Checklist' },
      { href: '/learn/ai-leadership-maturity-model/', label: 'Leadership maturity model' },
      { href: '/learn/ai-literacy-baseline-assessment/', label: 'AI literacy baseline assessment' },
    ],
  },
  {
    title: 'AI operating model for executives',
    desc: 'Choose this path if you need a repeatable executive operating rhythm, not just one-off pilots.',
    links: [
      { href: '/learn/ai-decision-intelligence-stack-executives/', label: 'Decision intelligence stack' },
      { href: '/learn/ai-signal-to-decision-operating-rhythm/', label: 'Signal-to-decision operating rhythm' },
      { href: '/learn/executive-decision-memo-template/', label: 'Executive decision memo template' },
    ],
  },
];
---

<Layout
  title="AI Governance Framework, AI Readiness Checklist, and AI Leadership Maturity Model | AILD"
  description="Practical executive resources for AI governance frameworks, AI readiness checklists, AI leadership and governance maturity models, board oversight, and AI operating models."
  canonical="https://aild.org/learn/"
  active="learn"
>
  <section class="hero">
    <p class="eyebrow">Evergreen resource library</p>
    <h1>AI governance framework, readiness checklist, and leadership maturity resources</h1>
    <p class="lead">
      Learn is AILD's evergreen library for executive AI search intent. Start here when you need a practical AI governance
      framework, AI readiness checklist, AI leadership and governance maturity model, board AI oversight model, executive
      decision template, or operating model guide.
    </p>
    <div class="badge-row">
      <span class="badge">{docs.length} evergreen guides</span>
      <span class="badge">Governance + readiness + operating model</span>
      <span class="badge">Weekly brief archive is separated from this ranking layer</span>
    </div>
  </section>

  <section class="section grid-3">
    {quickStarts.map((item) => (
      <article class="panel">
        <p class="eyebrow">Popular search intent</p>
        <h2>{item.title}</h2>
        <p>{item.desc}</p>
        <ul>
          {item.links.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </article>
    ))}
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Flagship pages</p>
        <h2>Six pages that should carry the main search authority</h2>
      </div>
      <p class="lead">These are the canonical assets for the core executive-intent topics AILD wants to own.</p>
    </div>
    <div class="article-list">
      {flagshipDocs.map((doc) => (
        <article class="article-item">
          <p class="tag">{doc.data.tags.join(' | ')}</p>
          <h2><a href={`/learn/${doc.slug}/`}>{doc.data.title}</a></h2>
          <p>{doc.data.description}</p>
          <p class="kb-meta">
            {doc.data.readingTime ? `Read time: ${doc.data.readingTime}` : ''}{doc.data.audience ? ` | Audience: ${doc.data.audience}` : ''}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Implementation layer</p>
        <h2>Supporting resources that feed the flagship pages</h2>
      </div>
      <p class="lead">Use these to move from framework understanding into operating cadence, rollout steps, and measurement.</p>
    </div>
    <div class="article-list">
      {implementationDocs.map((doc) => (
        <article class="article-item">
          <p class="tag">{doc.data.tags.join(' | ')}</p>
          <h2><a href={`/learn/${doc.slug}/`}>{doc.data.title}</a></h2>
          <p>{doc.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section panel">
    <h2>Find Exactly What You Need</h2>
    <p class="lead">Search and filter the evergreen library. Weekly Brief issues live on a separate editorial path.</p>
    <div class="kb-toolbar">
      <input id="kb-search" class="kb-search" type="search" placeholder="Search evergreen guides (e.g., governance, board, checklist, ROI)..." />
      <div class="kb-filters" id="kb-filters">
        <button class="kb-chip active" data-tag="all" type="button">All</button>
        {tags.map((tag) => (
          <button class="kb-chip" data-tag={tag.toLowerCase()} type="button">{tag}</button>
        ))}
      </div>
      <p class="kb-count"><span id="kb-count">{docs.length}</span> guides shown</p>
    </div>
    <p class="signal-note">Need the recurring editorial product instead? Use the <a href="/weekly-brief/">Weekly Brief archive</a>.</p>
  </section>

  <section class="section article-list" id="kb-list">
    {
      docs.map((doc) => (
        <article class="article-item kb-item" data-tags={doc.data.tags.map((t) => t.toLowerCase()).join(',')}>
          <p class="tag">{doc.data.tags.join(' | ')}</p>
          <h2>
            <a href={`/learn/${doc.slug}/`}>{doc.data.title}</a>
          </h2>
          <p>{doc.data.description}</p>
          <p class="kb-meta">
            {doc.data.readingTime ? `Read time: ${doc.data.readingTime}` : ''}{doc.data.audience ? ` | Audience: ${doc.data.audience}` : ''}
          </p>
          <p>
            Related:
            {doc.data.related.map((item) => (
              <>
                {' '}
                <a href={`/learn/${item}/`}>{item.replaceAll('-', ' ')}</a>{' '}
              </>
            ))}
          </p>
        </article>
      ))
    }
  </section>

  <script is:inline>
    (() => {
      const search = document.getElementById('kb-search');
      const chips = Array.from(document.querySelectorAll('.kb-chip'));
      const items = Array.from(document.querySelectorAll('.kb-item'));
      const count = document.getElementById('kb-count');
      if (!search || !items.length || !count) return;

      let activeTag = 'all';

      const apply = () => {
        const q = search.value.trim().toLowerCase();
        let visible = 0;

        items.forEach((item) => {
          const text = item.textContent.toLowerCase();
          const tags = (item.getAttribute('data-tags') || '').split(',');
          const matchTag = activeTag === 'all' || tags.includes(activeTag);
          const matchQuery = !q || text.includes(q);
          const show = matchTag && matchQuery;
          item.classList.toggle('kb-hidden', !show);
          if (show) visible += 1;
        });

        count.textContent = String(visible);
      };

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          chips.forEach((c) => c.classList.remove('active'));
          chip.classList.add('active');
          activeTag = chip.getAttribute('data-tag') || 'all';
          apply();
        });
      });

      search.addEventListener('input', apply);
      apply();
    })();
  </script>
</Layout>
