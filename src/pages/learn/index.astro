---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { buildCollectionPageSchema, buildItemListSchema } from '../../lib/schema';

const allDocs = await getCollection('docs');
const docs = allDocs
  .filter((doc) => !doc.data.tags.includes('weekly-brief'))
  .sort((a, b) => new Date(b.data.updatedDate ?? b.data.pubDate).getTime() - new Date(a.data.updatedDate ?? a.data.pubDate).getTime());
const tags = Array.from(
  docs
    .flatMap((doc) => doc.data.tags)
    .reduce((map, tag) => {
      const key = tag.toLowerCase();
      if (!map.has(key)) map.set(key, tag);
      return map;
    }, new Map<string, string>())
    .values(),
).sort((a, b) => a.localeCompare(b));

const implementationSlugs = [
  'ai-augmented-executive-workflow',
  'ai-assisted-strategic-review-playbook',
  'governance-lite-implementation',
  'decision-quality-scorecard-for-ai-teams',
  'ai-roi-dashboard-and-metrics',
  '90-day-ai-adoption-roadmap',
];

const implementationDocs = implementationSlugs
  .map((slug) => docs.find((doc) => doc.slug === slug))
  .filter(Boolean);

const featuredAnalysis = docs.find((doc) => doc.slug === 'openclaw-ai-agents-leadership-actions');

const quickStarts = [
  {
    title: 'AI governance framework',
    desc: 'Start here if your real question is how to govern AI use without slowing execution.',
    links: [
      { href: '/ai-governance/', label: 'AI Governance Framework for Executive Teams' },
      { href: '/learn/trust-vs-override-framework/', label: 'AI Trust vs Override Framework' },
      { href: '/learn/governance-lite-implementation/', label: 'Governance-Lite implementation guide' },
    ],
  },
  {
    title: 'AI readiness checklist',
    desc: 'Use this path when you need to assess leadership readiness before a broader rollout.',
    links: [
      { href: '/ai-leadership-readiness-checklist/', label: 'AI Readiness Checklist for Leaders' },
      { href: '/learn/ai-literacy-baseline-assessment/', label: 'AI readiness baseline assessment' },
      { href: '/learn/ai-leadership-maturity-model/', label: 'AI governance maturity model' },
    ],
  },
  {
    title: '90-day AI rollout plan',
    desc: 'Choose this path if you need a phased adoption plan with ownership, governance checkpoints, and review cadence.',
    links: [
      { href: '/90-day-rollout/', label: '90-Day AI Rollout Plan for Executive Teams' },
      { href: '/learn/90-day-ai-adoption-roadmap/', label: 'Detailed 90-day rollout guide' },
      { href: '/learn/ai-assisted-strategic-review-playbook/', label: 'AI-assisted strategic review playbook' },
    ],
  },
];

const pillarPages = [
  {
    href: '/ai-governance/',
    eyebrow: 'Pillar 1',
    title: 'AI Governance Framework for Executive Teams',
    desc: 'Own the AI governance framework cluster with decision rights, policy boundaries, trust and override rules, and maturity checkpoints.',
    links: [
      { href: '/learn/ai-policy-template-smb/', label: 'AI policy template' },
      { href: '/learn/trust-vs-override-framework/', label: 'Trust vs Override Framework' },
      { href: '/learn/ai-governance-committee-charter/', label: 'AI governance committee charter' },
    ],
  },
  {
    href: '/board-readiness/',
    eyebrow: 'Pillar 2',
    title: 'Board AI Governance and Oversight',
    desc: 'Own the board AI governance cluster with briefing structure, oversight cadence, board questions, and reporting expectations.',
    links: [
      { href: '/learn/board-ai-governance-briefing/', label: 'Board AI governance briefing template' },
      { href: '/learn/board-ai-oversight-checklist/', label: 'Board AI oversight checklist' },
      { href: '/learn/board-ai-reporting-template/', label: 'Board AI reporting template' },
    ],
  },
  {
    href: '/ai-leadership-readiness-checklist/',
    eyebrow: 'Pillar 3',
    title: 'AI Readiness Checklist for Leaders',
    desc: 'Own the AI readiness checklist cluster with leadership assessment, rollout readiness, policy readiness, and reporting readiness.',
    links: [
      { href: '/learn/ai-literacy-baseline-assessment/', label: 'AI readiness assessment scoring guide' },
      { href: '/learn/ai-leadership-maturity-model/', label: 'AI governance maturity model' },
      { href: '/board-readiness/', label: 'Board AI governance and oversight' },
    ],
  },
  {
    href: '/90-day-rollout/',
    eyebrow: 'Pillar 4',
    title: '90-Day AI Rollout Plan for Executive Teams',
    desc: 'Own the AI rollout plan cluster with phased adoption, executive ownership, implementation checkpoints, and operating follow-through.',
    links: [
      { href: '/learn/90-day-ai-adoption-roadmap/', label: '90-day AI adoption roadmap' },
      { href: '/learn/30-day-ai-rollout/', label: '30-day AI rollout checklist' },
      { href: '/learn/ai-assisted-strategic-review-playbook/', label: 'AI-assisted strategic review playbook' },
    ],
  },
  {
    href: '/executive-reporting/',
    eyebrow: 'Pillar 5',
    title: 'AI Executive Reporting and ROI Dashboard',
    desc: 'Own the AI ROI dashboard cluster with executive reporting, decision-quality metrics, board reporting, and KPI design.',
    links: [
      { href: '/learn/ai-roi-dashboard-and-metrics/', label: 'AI ROI dashboard and metrics' },
      { href: '/learn/executive-decision-memo-template/', label: 'Executive decision memo template' },
      { href: '/learn/executive-ai-reporting-cadence/', label: 'Executive AI reporting cadence' },
    ],
  },
  {
    href: '/ai-agents-governance/',
    eyebrow: 'Pillar 6',
    title: 'AI Agents Governance and Oversight',
    desc: 'Own the AI agents governance cluster with permissions, human oversight, workflow controls, escalation, and supervision.',
    links: [
      { href: '/learn/human-oversight-for-ai-agents/', label: 'Human oversight for AI agents' },
      { href: '/learn/agent-workflows-practical-guide/', label: 'Agent workflows practical guide' },
      { href: '/learn/openclaw-ai-agents-leadership-actions/', label: 'OpenClaw and agent governance implications' },
    ],
  },
];

const learnCollectionSchema = buildCollectionPageSchema({
  name: 'Executive AI Governance Pillars and Evergreen Resources',
  description:
    "AILD's evergreen library for AI governance frameworks, board AI oversight, AI readiness checklists, 90-day rollout planning, executive reporting, and AI agents governance.",
  url: '/learn/',
  items: pillarPages.map((page) => ({
    name: page.title,
    url: page.href,
    description: page.desc,
  })),
});

const pillarItemListSchema = buildItemListSchema({
  name: 'AILD Core Pillar Pages',
  items: pillarPages.map((page) => ({
    name: page.title,
    url: page.href,
  })),
});

const implementationItemListSchema = buildItemListSchema({
  name: 'AILD Implementation Resources',
  items: implementationDocs.map((doc) => ({
    name: doc.data.title,
    url: `/learn/${doc.slug}/`,
  })),
});
---

<Layout
  title="Executive AI Governance Pillars and Evergreen Resources | AILD"
  description="Explore AILD's evergreen pillar pages for AI governance frameworks, board AI oversight, AI readiness checklists, 90-day rollout planning, executive reporting, ROI dashboards, and AI agents governance."
  canonical="https://aild.org/learn/"
  active="learn"
  breadcrumbItems={[
    { label: 'Home', href: '/' },
    { label: 'Learn' },
  ]}
  pageRoleLabel="Evergreen hub"
  pageRoleContext="Cluster map and resource library"
  jsonLd={[learnCollectionSchema, pillarItemListSchema, implementationItemListSchema]}
>
  <section class="hero">
    <p class="eyebrow">Evergreen resource library</p>
    <h1>Executive AI pillar pages, frameworks, and implementation guides</h1>
    <p class="lead">
      Learn is AILD's evergreen library for the six executive AI topics the site is structured to own: AI governance
      framework, board AI oversight, AI readiness checklist, 90-day AI rollout plan, AI executive reporting and ROI
      dashboards, and AI agents governance. Start with the pillar that matches your question, then use the supporting
      frameworks, templates, and implementation guides underneath it.
    </p>
    <div class="badge-row">
      <span class="badge">{docs.length} evergreen guides</span>
      <span class="badge">Six ranking pillars</span>
      <span class="badge">Weekly brief archive is separated from this ranking layer</span>
    </div>
  </section>

  <section class="section grid-3">
    {quickStarts.map((item) => (
      <article class="panel">
        <p class="eyebrow">Popular search intent</p>
        <h2>{item.title}</h2>
        <p>{item.desc}</p>
        <ul>
          {item.links.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </article>
    ))}
  </section>

  {featuredAnalysis && (
    <section class="section panel">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Featured analysis</p>
          <h2>High-signal reading on AI agents and leadership action</h2>
        </div>
        <p class="lead">A recent standout piece worth surfacing for leaders tracking the shift from AI assistance to AI execution.</p>
      </div>
      <article class="article-item">
        <p class="tag">{featuredAnalysis.data.tags.join(' | ')}</p>
        <h2><a href={`/learn/${featuredAnalysis.slug}/`}>{featuredAnalysis.data.title}</a></h2>
        <p>{featuredAnalysis.data.description}</p>
        <p class="kb-meta">
          {featuredAnalysis.data.readingTime ? `Read time: ${featuredAnalysis.data.readingTime}` : ''}{featuredAnalysis.data.audience ? ` | Audience: ${featuredAnalysis.data.audience}` : ''}
        </p>
      </article>
    </section>
  )}

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Core pillar pages</p>
        <h2>Six pages that carry the main executive AI search authority</h2>
      </div>
      <p class="lead">These top-level pages are the canonical destinations for AILD's highest-value evergreen search intents.</p>
    </div>
    <div class="article-list">
      {pillarPages.map((page) => (
        <article class="article-item">
          <p class="tag">{page.eyebrow}</p>
          <h2><a href={page.href}>{page.title}</a></h2>
          <p>{page.desc}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Cluster map</p>
        <h2>Follow each pillar into its supporting topic cluster</h2>
      </div>
      <p class="lead">Use these links when you want the supporting framework, checklist, template, or implementation guide under a specific executive search intent.</p>
    </div>
    <div class="grid-3">
      {pillarPages.map((page) => (
        <article class="card">
          <h3><a href={page.href}>{page.title}</a></h3>
          <ul>
            {page.links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Implementation layer</p>
        <h2>Supporting resources that feed the pillar pages</h2>
      </div>
      <p class="lead">Use these to move from framework understanding into operating cadence, rollout steps, and measurement.</p>
    </div>
    <div class="article-list">
      {implementationDocs.map((doc) => (
        <article class="article-item">
          <p class="tag">{doc.data.tags.join(' | ')}</p>
          <h2><a href={`/learn/${doc.slug}/`}>{doc.data.title}</a></h2>
          <p>{doc.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section panel">
    <h2>Find Exactly What You Need</h2>
    <p class="lead">Search and filter the evergreen library. Weekly Brief issues live on a separate editorial path.</p>
    <div class="kb-toolbar">
      <input id="kb-search" class="kb-search" type="search" placeholder="Search evergreen guides (e.g., governance, board, checklist, ROI)..." />
      <div class="kb-filters" id="kb-filters">
        <button class="kb-chip active" data-tag="all" type="button">All</button>
        {tags.map((tag) => (
          <button class="kb-chip" data-tag={tag.toLowerCase()} type="button">{tag}</button>
        ))}
      </div>
      <p class="kb-count"><span id="kb-count">{docs.length}</span> guides shown</p>
    </div>
    <p class="signal-note">Need the recurring editorial product instead? Use the <a href="/weekly-brief/">Weekly Brief archive</a>.</p>
  </section>

  <section class="section article-list" id="kb-list">
    {
      docs.map((doc) => (
        <article class="article-item kb-item" data-tags={doc.data.tags.map((t) => t.toLowerCase()).join(',')}>
          <p class="tag">{doc.data.tags.join(' | ')}</p>
          <h2>
            <a href={`/learn/${doc.slug}/`}>{doc.data.title}</a>
          </h2>
          <p>{doc.data.description}</p>
          <p class="kb-meta">
            {doc.data.readingTime ? `Read time: ${doc.data.readingTime}` : ''}{doc.data.audience ? ` | Audience: ${doc.data.audience}` : ''}
          </p>
          <p>
            Related:
            {doc.data.related.map((item) => (
              <>
                {' '}
                <a href={`/learn/${item}/`}>{item.replaceAll('-', ' ')}</a>{' '}
              </>
            ))}
          </p>
        </article>
      ))
    }
  </section>

  <script is:inline>
    (() => {
      const search = document.getElementById('kb-search');
      const chips = Array.from(document.querySelectorAll('.kb-chip'));
      const items = Array.from(document.querySelectorAll('.kb-item'));
      const count = document.getElementById('kb-count');
      if (!search || !items.length || !count) return;

      let activeTag = 'all';

      const apply = () => {
        const q = search.value.trim().toLowerCase();
        let visible = 0;

        items.forEach((item) => {
          const text = item.textContent.toLowerCase();
          const tags = (item.getAttribute('data-tags') || '').split(',');
          const matchTag = activeTag === 'all' || tags.includes(activeTag);
          const matchQuery = !q || text.includes(q);
          const show = matchTag && matchQuery;
          item.classList.toggle('kb-hidden', !show);
          if (show) visible += 1;
        });

        count.textContent = String(visible);
      };

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          chips.forEach((c) => c.classList.remove('active'));
          chip.classList.add('active');
          activeTag = chip.getAttribute('data-tag') || 'all';
          apply();
        });
      });

      search.addEventListener('input', apply);
      apply();
    })();
  </script>
</Layout>
