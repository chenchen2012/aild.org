---
import Layout from '../layouts/Layout.astro';

const priorityPaths = [
  {
    title: 'Board Readiness',
    summary: 'Clarify what the board needs to review before AI adoption expands across the organization.',
    audience: 'For CEOs, COOs, governance owners, and board-facing operators.',
    href: '/board-readiness/',
    cta: 'Review the Board Readiness Path',
  },
  {
    title: 'AI Governance',
    summary: 'Set decision rights, control points, and governance structure before AI use spreads unevenly.',
    audience: 'For governance owners, transformation leaders, and senior operators responsible for risk and rollout discipline.',
    href: '/ai-governance/',
    cta: 'See the Governance Framework',
  },
  {
    title: '90-Day Rollout',
    summary: 'Move from scattered pilots to a managed 90-day adoption plan with clear leadership ownership.',
    audience: 'For COOs, strategy leaders, and transformation teams responsible for execution.',
    href: '/90-day-rollout/',
    cta: 'Open the 90-Day Rollout Plan',
  },
  {
    title: 'Executive Reporting',
    summary: 'Create reporting leaders and boards can actually use to track progress, risk, and accountability.',
    audience: 'For executives responsible for updates, reviews, and board preparation.',
    href: '/executive-reporting/',
    cta: 'Use the Executive Reporting Tools',
  },
  {
    title: 'Operating Rhythm',
    summary: 'Establish a repeatable leadership cadence for reviewing signals, making decisions, and managing follow-through.',
    audience: 'For leadership teams building AI into recurring operating reviews.',
    href: '/operating-rhythm/',
    cta: 'See Operating Rhythm Models',
  },
];

const pressurePoints = [
  {
    title: 'Set governance before AI use spreads',
    summary: 'Create clear ownership, escalation rules, review points, and boundaries before teams normalize ad hoc AI use.',
  },
  {
    title: 'Give the board a clear oversight view',
    summary: 'Translate AI activity into board-ready oversight questions, risk visibility, and leadership accountability.',
  },
  {
    title: 'Move from pilots to a managed 90-day rollout',
    summary: 'Replace fragmented experimentation with a sequenced adoption plan tied to leadership review and execution discipline.',
  },
  {
    title: 'Create reporting leaders can actually use',
    summary: 'Build reporting that supports decisions, not just activity summaries.',
  },
  {
    title: 'Establish a repeatable operating rhythm',
    summary: 'Turn AI oversight into a recurring management practice rather than a one-off initiative.',
  },
];

const flagshipAssets = [
  {
    title: 'AI Governance Framework',
    href: '/learn/trust-vs-override-framework/',
    summary: 'Use this to define governance structure, control points, and leadership accountability.',
  },
  {
    title: 'Board AI Governance Briefing',
    href: '/learn/board-ai-governance-briefing/',
    summary: 'Use this to prepare board-level discussion and oversight framing.',
  },
  {
    title: 'AI Leadership Readiness Checklist',
    href: '/ai-leadership-readiness-checklist/',
    summary: 'Use this to assess whether leadership systems are ready before adoption expands.',
  },
  {
    title: '90-Day AI Adoption Roadmap',
    href: '/learn/90-day-ai-adoption-roadmap/',
    summary: 'Use this to structure the first managed rollout window.',
  },
  {
    title: 'Executive Decision Memo Template',
    href: '/learn/executive-decision-memo-template/',
    summary: 'Use this to standardize executive review, decisions, and follow-through.',
  },
  {
    title: 'AI Signal-to-Decision Operating Rhythm',
    href: '/learn/ai-signal-to-decision-operating-rhythm/',
    summary: 'Use this to establish a repeatable cadence for leadership review and action.',
  },
];

const proofItems = [
  {
    title: 'Case snapshots',
    summary: 'Short examples showing how executive teams structure oversight, reporting, and rollout decisions.',
  },
  {
    title: 'Implementation patterns',
    summary: 'Practical patterns for sequencing governance, pilots, reporting, and operating reviews.',
  },
  {
    title: 'Decision signals',
    summary: 'The indicators leaders should watch when AI adoption moves from experimentation to managed execution.',
  },
];

const credibilityItems = [
  { title: 'About AILD', href: '/about/', summary: 'See who AILD is for and how the platform is positioned.' },
  { title: 'Founder-Editor', href: '/author/', summary: 'See the named editorial ownership behind the work.' },
  { title: 'Editorial Standards', href: '/editorial-standards/', summary: 'Review how pages are selected, updated, and maintained.' },
  { title: 'Research Method', href: '/research/', summary: 'Use the evidence base behind frameworks, examples, and guidance.' },
];
---

<Layout
  title="AI leadership for decisionmakers responsible for governance, rollout, and oversight | AILD"
  description="AILD helps leadership teams build AI governance, prepare board-ready reporting, and establish operating discipline before adoption scales."
  canonical="https://aild.org/"
  active="home"
  alternates={[
    { hreflang: 'en', href: 'https://aild.org/' },
    { hreflang: 'zh-CN', href: 'https://aild.org/zh/' },
    { hreflang: 'zh', href: 'https://aild.org/zh/' },
    { hreflang: 'x-default', href: 'https://aild.org/' },
  ]}
>
  <section class="hero home-hero">
    <div class="home-hero-grid">
      <div>
        <p class="eyebrow">AILD | AI Leadership for Decisionmakers</p>
        <h1>AI leadership for decisionmakers responsible for governance, rollout, and oversight</h1>
        <p class="lead">AILD helps leadership teams build AI governance, prepare board-ready reporting, and establish operating discipline before adoption scales.</p>
        <p class="signal-note">Built for CEOs, COOs, strategy leaders, transformation owners, governance leads, and board-facing operators.</p>
        <div class="stack">
          <a class="btn btn-primary" href="#priority-paths">Start with Your Priority Path</a>
          <a class="btn btn-secondary" href="/advisory/">Request Executive Briefing</a>
        </div>
      </div>
      <div class="panel home-hero-aside">
        <p class="eyebrow">Executive snapshot</p>
        <div class="snapshot-item">
          <strong>Governance</strong>
          <span>Define control points before AI use spreads.</span>
        </div>
        <div class="snapshot-item">
          <strong>Reporting</strong>
          <span>Prepare board-ready visibility and accountability.</span>
        </div>
        <div class="snapshot-item">
          <strong>Operating rhythm</strong>
          <span>Turn pilots into a managed leadership cadence.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="priority-paths">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Priority paths</p>
        <h2>Choose the business priority you need to address first</h2>
      </div>
      <p class="lead">AILD is organized around the executive decisions that shape AI adoption, oversight, and operating discipline.</p>
    </div>
    <div class="proof-grid">
      {priorityPaths.map((path) => (
        <article class="panel home-path-card">
          <h2>{path.title}</h2>
          <p>{path.summary}</p>
          <p class="kb-meta">{path.audience}</p>
          <a class="text-link" href={path.href}>{path.cta}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Decision pressure</p>
        <h2>What leaders need to get right before AI scales</h2>
      </div>
      <p class="lead">Most organizations do not fail because they lack AI activity. They fail because governance, reporting, and operating discipline lag behind adoption.</p>
    </div>
    <div class="urgency-strip">
      {pressurePoints.map((item) => (
        <article class="urgency-card">
          <strong>{item.title}</strong>
          <span>{item.summary}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Flagship executive assets</p>
        <h2>Start with the executive assets that carry the most decision value</h2>
      </div>
      <p class="lead">These are the core frameworks and tools for leaders shaping AI oversight, rollout, and operating discipline.</p>
    </div>
    <div class="article-list home-featured-grid">
      {flagshipAssets.map((asset) => (
        <article class="article-item home-featured-item">
          <h3><a href={asset.href}>{asset.title}</a></h3>
          <p>{asset.summary}</p>
        </article>
      ))}
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="#priority-paths">See the Executive Priority Paths</a>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Proof</p>
        <h2>What this looks like in practice</h2>
      </div>
      <p class="lead">AILD does not stop at frameworks. It connects executive guidance to implementation patterns, reporting structure, and real leadership use cases.</p>
    </div>
    <div class="proof-grid">
      {proofItems.map((item) => (
        <article class="panel">
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="/cases/">Review Executive Examples</a>
    </div>
  </section>

  <section class="section split-callout">
    <div>
      <p class="eyebrow">Executive advisory</p>
      <h2>Bring this into a live leadership context</h2>
      <p>Use AILD as a decision support layer, an executive workshop input, or a governance design starting point.</p>
      <p class="signal-note">This is for leadership teams that need sharper alignment on governance, reporting, rollout priorities, and operating discipline.</p>
      <div class="stack">
        <a class="btn btn-primary" href="/advisory/">Discuss Advisory Support</a>
      </div>
    </div>
    <div class="panel">
      <p class="eyebrow">Good fit</p>
      <ul class="mini-list">
        <li>Leadership teams preparing for board review</li>
        <li>Transformation teams moving beyond isolated pilots</li>
        <li>Governance owners tightening accountability and reporting</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Credibility</p>
        <h2>Why AILD is credible</h2>
      </div>
      <p class="lead">AILD is built to support executive judgment with clear standards, visible editorial responsibility, and evidence-backed frameworks.</p>
    </div>
    <div class="proof-grid">
      {credibilityItems.map((item) => (
        <article class="panel">
          <h3><a href={item.href}>{item.title}</a></h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-callout home-cta-band">
    <div>
      <p class="eyebrow">Weekly Brief</p>
      <h2>Get the Weekly Brief for senior AI decisionmaking</h2>
      <p>Use the Weekly Brief to stay current on the shifts, signals, and operating questions leadership teams need to track as AI adoption evolves.</p>
      <div class="stack">
        <a class="btn btn-primary" href="/weekly-brief/">Subscribe to the Weekly Brief</a>
      </div>
    </div>
    <div class="panel home-brief-panel">
      <p class="eyebrow">What it includes</p>
      <ul class="mini-list">
        <li>Executive summaries of major AI shifts</li>
        <li>Board and governance implications worth tracking</li>
        <li>Operating questions that affect rollout discipline</li>
      </ul>
    </div>
  </section>
</Layout>
