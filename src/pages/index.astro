---
import Layout from '../layouts/Layout.astro';

const priorityPaths = [
  {
    title: 'Board Readiness',
    summary: 'Clarify what the board should review before AI use expands across the business.',
    audience: 'For executives and governance leaders.',
    href: '/board-readiness/',
    cta: 'Browse board oversight guidance',
  },
  {
    title: 'AI Governance',
    summary: 'Set decision rights, review points, and control structure before AI rollout gets ahead of oversight.',
    audience: 'For governance leaders and transformation leaders.',
    href: '/ai-governance/',
    cta: 'Browse AI governance resources',
  },
  {
    title: '90-Day Rollout',
    summary: 'Move from scattered pilots to a managed AI rollout plan with clear ownership and review.',
    audience: 'For executives and transformation leaders.',
    href: '/90-day-rollout/',
    cta: 'See the rollout plan',
  },
  {
    title: 'Executive Reporting',
    summary: 'Create reporting executives and boards can use to track progress, risk, and accountability.',
    audience: 'For executives and governance leaders.',
    href: '/executive-reporting/',
    cta: 'Open reporting tools',
  },
  {
    title: 'Operating Rhythm',
    summary: 'Build a repeatable AI operating cadence for review, decision-making, and follow-through.',
    audience: 'For executives and transformation leaders.',
    href: '/operating-rhythm/',
    cta: 'Explore the operating model',
  },
];

const pressurePoints = [
  {
    title: 'Set governance before AI use spreads',
    summary: 'Put ownership, escalation rules, review points, and policy boundaries in place before ad hoc use becomes normal.',
  },
  {
    title: 'Give the board a usable oversight view',
    summary: 'Turn AI activity into board-ready questions, risk visibility, and executive accountability.',
  },
  {
    title: 'Move from pilots to a managed rollout',
    summary: 'Replace fragmented experimentation with a sequenced adoption plan tied to review and execution discipline.',
  },
  {
    title: 'Create reporting that supports decisions',
    summary: 'Build reporting that helps leaders decide what to do next, not just summarize activity.',
  },
  {
    title: 'Build a working AI operating rhythm',
    summary: 'Make AI oversight part of the management system rather than a one-off initiative.',
  },
];

const flagshipAssets = [
  {
    title: 'AI Governance Framework for Executive Teams',
    href: '/learn/trust-vs-override-framework/',
    summary: 'Define governance structure, control points, and accountability before rollout accelerates.',
  },
  {
    title: 'Board AI Governance Briefing Template',
    href: '/learn/board-ai-governance-briefing/',
    summary: 'Prepare board-level discussion, oversight questions, and decision framing.',
  },
  {
    title: 'AI Readiness Checklist for Leaders',
    href: '/ai-leadership-readiness-checklist/',
    summary: 'Assess whether governance, oversight, and operating systems are ready before adoption expands.',
  },
  {
    title: '90-Day AI Rollout Plan',
    href: '/learn/90-day-ai-adoption-roadmap/',
    summary: 'Structure the first serious rollout window with clear priorities, owners, and review points.',
  },
  {
    title: 'Executive Decision Memo Template',
    href: '/learn/executive-decision-memo-template/',
    summary: 'Standardize executive review, decisions, and follow-through across AI initiatives.',
  },
  {
    title: 'AI Operating Rhythm for Executive Teams',
    href: '/learn/ai-signal-to-decision-operating-rhythm/',
    summary: 'Build a repeatable operating rhythm for AI signals, decisions, and action.',
  },
];

const proofItems = [
  {
    title: 'Case snapshots',
    summary: 'Short examples showing how teams structure oversight, reporting, and rollout decisions.',
  },
  {
    title: 'Implementation patterns',
    summary: 'Practical ways to sequence governance, pilots, reporting, and operating reviews.',
  },
  {
    title: 'Decision signals',
    summary: 'The indicators decisionmakers should watch as AI moves from experimentation to managed execution.',
  },
];

const credibilityItems = [
  { title: 'About AILD', href: '/about/', summary: 'See who AILD is for and how the site approaches governance, rollout, and oversight.' },
  { title: 'Editorial Responsibility', href: '/author/', summary: 'See how the site is edited, maintained, and reviewed.' },
  { title: 'Editorial Standards', href: '/editorial-standards/', summary: 'Review how frameworks, tools, and briefings are selected and maintained.' },
  { title: 'Research Method', href: '/research/', summary: 'See the evidence base behind the site’s guidance, tools, and examples.' },
];
---

<Layout
  title="AI Lab for Decisionmakers | AILD"
  description="AILD helps executives, transformation leaders, and governance leaders make practical decisions about AI governance, readiness, board oversight, 90-day rollout planning, executive reporting, and operating cadence."
  canonical="https://aild.org/"
  active="home"
  showUpdatedStamp={false}
  alternates={[
    { hreflang: 'en', href: 'https://aild.org/' },
    { hreflang: 'zh-CN', href: 'https://aild.org/zh/' },
    { hreflang: 'zh', href: 'https://aild.org/zh/' },
    { hreflang: 'x-default', href: 'https://aild.org/' },
  ]}
>
  <section class="hero home-hero">
    <div class="home-hero-grid">
      <div class="home-hero-main">
        <p class="eyebrow">AI Lab for Decisionmakers</p>
        <h1>For decisionmakers building control before AI scales</h1>
        <p class="lead">AILD helps executives, transformation leaders, and governance leaders make practical decisions about AI governance, readiness, board oversight, and operating cadence.</p>
        <div class="home-hero-proofline">
          <span>Frameworks, checklists, templates, and briefings for executives, transformation leaders, and governance leaders</span>
        </div>
        <div class="stack">
          <a class="btn btn-primary" href="#core-resources">Browse core resources</a>
          <a class="btn btn-secondary" href="/advisory/">Book an executive briefing</a>
        </div>
      </div>
      <div class="panel home-hero-aside">
        <p class="eyebrow">Who this is for</p>
        <div class="snapshot-item">
          <strong>Executives</strong>
          <span>Make clearer decisions about AI readiness, board oversight, and operating priorities.</span>
        </div>
        <div class="snapshot-item">
          <strong>Transformation leaders</strong>
          <span>Turn scattered pilots into a governed rollout with clear ownership and review.</span>
        </div>
        <div class="snapshot-item">
          <strong>Governance leaders</strong>
          <span>Set decision rights, controls, and escalation paths before AI use outruns oversight.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-section" id="priority-paths">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>Choose the problem you need to solve first</h2>
      </div>
      <p class="lead">AILD is organized around the practical decisions that shape AI governance, rollout, executive oversight, and operating discipline.</p>
    </div>
    <div class="proof-grid">
      {priorityPaths.map((path) => (
        <article class="panel home-path-card">
          <h2>{path.title}</h2>
          <p>{path.summary}</p>
          <p class="kb-meta">{path.audience}</p>
          <a class="text-link" href={path.href}>{path.cta}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section panel home-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">What it solves</p>
        <h2>What needs attention before AI scales</h2>
      </div>
      <p class="lead">The challenge is rarely AI activity itself. The challenge is whether governance, oversight, reporting, and rollout discipline are strong enough to support it.</p>
    </div>
    <div class="urgency-strip">
      {pressurePoints.map((item) => (
        <article class="urgency-card">
          <strong>{item.title}</strong>
          <span>{item.summary}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section home-section home-featured-section" id="core-resources">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Core resources</p>
        <h2>Six core resources to start with</h2>
      </div>
      <p class="lead">These pages cover the core questions around AI governance, rollout, readiness, board oversight, and operating models.</p>
    </div>
    <div class="article-list home-featured-grid">
      {flagshipAssets.map((asset) => (
        <article class="article-item home-featured-item">
          <h3><a href={asset.href}>{asset.title}</a></h3>
          <p>{asset.summary}</p>
        </article>
      ))}
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="/ai-leadership-readiness-checklist/">Get the checklist</a>
    </div>
  </section>

  <section class="section home-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">What good looks like</p>
        <h2>What this looks like in practice</h2>
      </div>
      <p class="lead">AILD combines practical frameworks with implementation patterns, reporting structure, and real-world examples leaders can actually use.</p>
    </div>
    <div class="proof-grid">
      {proofItems.map((item) => (
        <article class="panel">
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="/cases/">See case examples</a>
    </div>
  </section>

  <section class="section split-callout home-section">
    <div>
      <p class="eyebrow">Executive advisory</p>
      <h2>Bring this into a live decision-making context</h2>
      <p>Use AILD as a practical input for AI governance design, rollout planning, executive review, and board-facing discussion.</p>
      <p class="signal-note">Best suited to teams that need sharper alignment on governance, rollout priorities, accountability, and operating cadence.</p>
      <div class="stack">
        <a class="btn btn-primary" href="/advisory/">Request a tailored advisory session</a>
      </div>
    </div>
    <div class="panel">
      <p class="eyebrow">Good fit</p>
      <ul class="mini-list">
        <li>Executives preparing for board review</li>
        <li>Transformation leaders moving beyond isolated pilots</li>
        <li>Governance leaders tightening accountability and reporting</li>
      </ul>
    </div>
  </section>

  <section class="section home-section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Why AILD</p>
        <h2>Editorial judgment, practical tools, and useful evidence</h2>
      </div>
      <p class="lead">AILD is for executives and transformation leaders responsible for AI rollout, governance, and oversight, especially those who need business clarity rather than technical noise.</p>
    </div>
    <div class="proof-grid">
      {credibilityItems.map((item) => (
        <article class="panel">
          <h3><a href={item.href}>{item.title}</a></h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-callout home-cta-band">
    <div>
      <p class="eyebrow">Weekly Brief</p>
      <h2>Read the Weekly Brief between major decisions</h2>
      <p>Use the Weekly Brief to stay current on AI governance, rollout, and oversight between major updates, without getting buried in technical noise.</p>
      <div class="stack">
        <a class="btn btn-primary" href="/weekly-brief/">Read the Weekly Brief</a>
      </div>
    </div>
    <div class="panel home-brief-panel">
      <p class="eyebrow">What it includes</p>
      <ul class="mini-list">
        <li>Concise updates for executives and transformation leaders</li>
        <li>Board oversight and governance implications worth tracking</li>
        <li>Rollout and operating-model questions that need attention</li>
      </ul>
    </div>
  </section>
</Layout>
