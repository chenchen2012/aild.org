---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
const docsBySlug = new Map(docs.map((doc) => [doc.slug, doc]));
const featuredDocSlugs = [
  'ai-decision-intelligence-stack-executives',
  'trust-vs-override-framework',
  'ai-leadership-maturity-model',
];
const featuredDocs = featuredDocSlugs
  .map((slug) => docsBySlug.get(slug))
  .filter((doc): doc is NonNullable<typeof doc> => Boolean(doc));
---

<Layout
  title="AI Leadership Frameworks, Governance, and Executive Decision-Making | AILD"
  description="Executive AI leadership frameworks for decision-making, AI governance, operating models, and management workflows. Learn how leaders use AI without losing accountability."
  canonical="https://aild.org/"
  active="home"
  alternates={[
    { hreflang: 'en', href: 'https://aild.org/' },
    { hreflang: 'zh-CN', href: 'https://aild.org/zh/' },
    { hreflang: 'zh', href: 'https://aild.org/zh/' },
    { hreflang: 'x-default', href: 'https://aild.org/' },
  ]}
>
  <section class="hero home-hero">
    <div class="home-hero-grid">
      <div>
        <p class="eyebrow">Leadership in the decision intelligence era</p>
        <h1>AI leadership frameworks for executive decision-making and governance</h1>
        <p class="lead">
          AILD helps CEOs, strategy leaders, and transformation teams build an AI operating model for management. Learn how to use AI in executive decision-making, set governance rules, define trust vs override boundaries, and run repeatable leadership workflows.
        </p>
        <div class="home-proofline">
          <span>For CEOs and executive teams</span>
          <span>For strategy and ops leads</span>
          <span>For AI transformation owners</span>
        </div>
        <div class="stack">
          <a class="btn btn-primary" href="/learn/ai-decision-intelligence-stack-executives/">Start with Decision Intelligence</a>
          <a class="btn btn-secondary" href="/playbooks/">See operating playbooks</a>
        </div>
      </div>
      <aside class="signal-panel">
        <p class="eyebrow">What you get</p>
        <h2>Move from AI pilots to a real executive AI operating model</h2>
        <ul class="signal-list">
          <li><strong>AI decision-making frameworks:</strong> clarify rights, ownership, and evidence thresholds.</li>
          <li><strong>AI governance rules:</strong> define when AI assists and when humans override.</li>
          <li><strong>Executive operating cadence:</strong> convert signal into action, review, and measured outcomes.</li>
        </ul>
        <div class="signal-callout">
          <strong>Best first click:</strong>
          <a href="/learn/ai-decision-intelligence-stack-executives/"> AI Decision Intelligence Stack</a>
        </div>
      </aside>
    </div>
    <div class="metrics home-metrics">
      <div class="metric"><strong>Faster cycles</strong><span>Shorten strategic review-to-decision time</span></div>
      <div class="metric"><strong>Higher quality</strong><span>Improve decision consistency with clear frameworks</span></div>
      <div class="metric"><strong>Better control</strong><span>Define when to trust AI vs override it</span></div>
    </div>
  </section>

  <section class="section">
    <div class="home-path-grid">
      <article class="home-path-card panel">
        <p class="eyebrow">If you are setting strategy</p>
        <h2>Start with the AI leadership model</h2>
        <p>Understand the executive decision stack, trust boundaries, and governance logic before choosing AI tools.</p>
        <a class="text-link" href="/learn/ai-decision-intelligence-stack-executives/">Read the executive framework</a>
      </article>
      <article class="home-path-card panel">
        <p class="eyebrow">If you are running execution</p>
        <h2>Start with management playbooks and templates</h2>
        <p>Install repeatable operating rhythm, meeting protocols, scorecards, and decision briefs for AI-assisted execution.</p>
        <a class="text-link" href="/playbooks/">Open implementation playbooks</a>
      </article>
      <article class="home-path-card panel">
        <p class="eyebrow">If you need proof</p>
        <h2>Start with AI governance evidence and cases</h2>
        <p>Use research references and case structures to justify the operating model internally and support leadership buy-in.</p>
        <a class="text-link" href="/research/">Review evidence base</a>
      </article>
    </div>
  </section>

  <section class="section home-proof">
    <article class="panel">
      <p class="eyebrow">Leadership gap</p>
      <h2>Why many enterprise AI programs stall before strategic value appears</h2>
      <p>
        Teams buy AI tools fast, but leadership systems lag behind. Without an executive decision architecture, AI output remains tactical. AILD closes this gap with practical frameworks for executive judgment, AI governance, and operating discipline.
      </p>
      <div class="kpi-strip">
        <div class="kpi"><strong>Week 1</strong>Decision map + risk tiers</div>
        <div class="kpi"><strong>Week 2</strong>Trust-vs-override rules + logs</div>
        <div class="kpi"><strong>Week 3-4</strong>Executive workflow + outcome review cadence</div>
      </div>
    </article>
    <article class="story-note">
      <p class="eyebrow">What world-class teams do differently</p>
      <ul>
        <li>Treat decision quality as the primary AI KPI</li>
        <li>Separate AI analysis from human accountability</li>
        <li>Run weekly decision reviews to calibrate judgment</li>
      </ul>
      <p>
        See implementation proofs on <a href="/cases/">Cases</a> and
        evidence basis on <a href="/research/">Research</a>.
      </p>
    </article>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>Best AI leadership and governance guides to read first</h2>
      </div>
      <p class="lead">
        Begin with the core pages leaders usually need first, then expand into the full library of {docs.length} practical guides on AI leadership, governance, and executive workflows.
      </p>
    </div>
    <div class="article-list section home-featured-grid">
      {
        featuredDocs.map((doc) => (
          <article class="article-item home-featured-item">
            <p class="tag">{doc.data.tags.join(' | ')}</p>
            <h3>
              <a href={`/learn/${doc.slug}/`}>{doc.data.title}</a>
            </h3>
            <p>{doc.data.description}</p>
            <p class="kb-meta">
              {doc.data.readingTime ? `Read time: ${doc.data.readingTime}` : ''}{doc.data.audience ? ` | Audience: ${doc.data.audience}` : ''}
            </p>
          </article>
        ))
      }
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="/learn/">Browse full leadership knowledge library</a>
      <a class="btn btn-secondary" href="/zh/">View Chinese homepage</a>
    </div>
  </section>
</Layout>
