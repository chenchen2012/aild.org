---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const docs = (await getCollection('docs')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
const featuredDocs = docs.slice(0, 3);
---

<Layout
  title="AI Leadership and Development (AILD)"
  description="AILD (AI Leadership and Development): Build decision intelligence, AI-augmented leadership workflows, and measurable execution outcomes."
  canonical="https://aild.org/"
  active="home"
  alternates={[
    { hreflang: 'en', href: 'https://aild.org/' },
    { hreflang: 'zh-CN', href: 'https://aild.org/zh/' },
    { hreflang: 'zh', href: 'https://aild.org/zh/' },
    { hreflang: 'x-default', href: 'https://aild.org/' },
  ]}
>
  <section class="hero home-hero reveal">
    <div class="home-hero-grid">
      <div>
        <p class="eyebrow">Leadership in the decision intelligence era</p>
        <h1>AI Leadership and Development (AILD)</h1>
        <p class="lead">
          AILD helps leadership teams turn AI from scattered output into a governed
          decision system. Use it to define where AI assists, where leaders decide,
          and how execution gets measured every week.
        </p>
        <div class="home-proofline">
          <span>For CEOs and executive teams</span>
          <span>For strategy and ops leads</span>
          <span>For AI transformation owners</span>
        </div>
        <div class="stack">
          <a class="btn btn-primary" href="/learn/ai-decision-intelligence-stack-executives/">Start with Decision Intelligence</a>
          <a class="btn btn-secondary" href="/playbooks/">See operating playbooks</a>
        </div>
      </div>
      <aside class="signal-panel">
        <p class="eyebrow">What you get</p>
        <h2>Move from AI experimentation to leadership operating discipline</h2>
        <ul class="signal-list">
          <li><strong>Decision frameworks:</strong> clarify rights, ownership, and evidence thresholds.</li>
          <li><strong>Trust controls:</strong> define when AI assists and when humans override.</li>
          <li><strong>Execution cadence:</strong> convert signal into action, review, and measured outcomes.</li>
        </ul>
        <div class="signal-callout">
          <strong>Best first click:</strong>
          <a href="/learn/ai-decision-intelligence-stack-executives/"> AI Decision Intelligence Stack</a>
        </div>
      </aside>
    </div>
    <div class="metrics home-metrics">
      <div class="metric"><strong>Faster cycles</strong><span>Shorten strategic review-to-decision time</span></div>
      <div class="metric"><strong>Higher quality</strong><span>Improve decision consistency with clear frameworks</span></div>
      <div class="metric"><strong>Better control</strong><span>Define when to trust AI vs override it</span></div>
    </div>
  </section>

  <section class="section reveal delay-1">
    <div class="home-path-grid">
      <article class="home-path-card panel">
        <p class="eyebrow">If you are setting strategy</p>
        <h2>Start with the leadership model</h2>
        <p>Understand the decision stack, trust boundaries, and governance logic before choosing tools.</p>
        <a class="text-link" href="/learn/ai-decision-intelligence-stack-executives/">Read the executive framework</a>
      </article>
      <article class="home-path-card panel">
        <p class="eyebrow">If you are running execution</p>
        <h2>Start with playbooks and templates</h2>
        <p>Install repeatable operating rhythm, meeting protocols, scorecards, and decision briefs.</p>
        <a class="text-link" href="/playbooks/">Open implementation playbooks</a>
      </article>
      <article class="home-path-card panel">
        <p class="eyebrow">If you need proof</p>
        <h2>Start with evidence and cases</h2>
        <p>Use research references and case structures to justify the operating model internally.</p>
        <a class="text-link" href="/research/">Review evidence base</a>
      </article>
    </div>
  </section>

  <section class="section home-proof reveal delay-2">
    <article class="panel">
      <p class="eyebrow">Leadership gap</p>
      <h2>Why many AI programs stall before strategic value appears</h2>
      <p>
        Teams buy tools fast, but leadership systems lag behind. Without a
        decision architecture, AI output remains tactical. AILD closes this gap
        with practical frameworks for executive judgment and execution.
      </p>
      <div class="kpi-strip">
        <div class="kpi"><strong>Week 1</strong>Decision map + risk tiers</div>
        <div class="kpi"><strong>Week 2</strong>Trust-vs-override rules + logs</div>
        <div class="kpi"><strong>Week 3-4</strong>Executive workflow + outcome review cadence</div>
      </div>
    </article>
    <article class="story-note">
      <p class="eyebrow">What world-class teams do differently</p>
      <ul>
        <li>Treat decision quality as the primary AI KPI</li>
        <li>Separate AI analysis from human accountability</li>
        <li>Run weekly decision reviews to calibrate judgment</li>
      </ul>
      <p>
        See implementation proofs on <a href="/cases/">Cases</a> and
        evidence basis on <a href="/research/">Research</a>.
      </p>
    </article>
  </section>

  <section class="section reveal delay-3">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Start here</p>
        <h2>Flagship leadership guides</h2>
      </div>
      <p class="lead">
        Begin with the core pieces leaders usually need first, then expand into the full library of {docs.length} practical guides.
      </p>
    </div>
    <div class="article-list section home-featured-grid">
      {
        featuredDocs.map((doc) => (
          <article class="article-item home-featured-item">
            <p class="tag">{doc.data.tags.join(' | ')}</p>
            <h3>
              <a href={`/learn/${doc.slug}/`}>{doc.data.title}</a>
            </h3>
            <p>{doc.data.description}</p>
            <p class="kb-meta">
              {doc.data.readingTime ? `Read time: ${doc.data.readingTime}` : ''}{doc.data.audience ? ` | Audience: ${doc.data.audience}` : ''}
            </p>
          </article>
        ))
      }
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="/learn/">Browse full leadership knowledge library</a>
      <a class="btn btn-secondary" href="/zh/">View Chinese homepage</a>
    </div>
  </section>
</Layout>
