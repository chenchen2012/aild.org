  robots="noindex,follow"
  lang="zh-CN"
>
  <section class="hero">
    <p class="eyebrow">已收到申请</p>
    <h1>你已进入每周简报申请名单</h1>
    <p class="lead">你可以先继续浏览AILD的简报、清单和服务页面。</p>
    <div class="stack">
      <a class="btn btn-primary" href="/zh/weekly-brief/">返回每周简报页</a>
      <a class="btn btn-secondary" href="/zh/ai-leadership-readiness-checklist/">查看准备度清单</a>
    </div>
  </section>
</Layout>
