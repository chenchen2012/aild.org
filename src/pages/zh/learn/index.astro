---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allDocs = await getCollection('zhdocs');
const docs = allDocs
  .filter((doc) => !doc.data.tags.includes('weekly-brief'))
  .sort((a, b) => new Date(b.data.updatedDate ?? b.data.pubDate).getTime() - new Date(a.data.updatedDate ?? a.data.pubDate).getTime());
const tags = Array.from(new Set(docs.flatMap((d) => d.data.tags))).sort();

const flagshipSlugs = [
  'ai-leadership-maturity-model',
  'ai-decision-intelligence-stack-executives',
  'trust-vs-override-framework',
  'board-ai-governance-briefing',
  'executive-decision-memo-template',
  'ai-signal-to-decision-operating-rhythm',
];

const implementationSlugs = [
  'ai-augmented-executive-workflow',
  'ai-assisted-strategic-review-playbook',
  'governance-lite-implementation',
  'decision-quality-scorecard-for-ai-teams',
  'ai-roi-dashboard-and-metrics',
  '90-day-ai-adoption-roadmap',
];

const flagshipDocs = flagshipSlugs
  .map((slug) => docs.find((doc) => doc.slug === slug))
  .filter(Boolean);

const implementationDocs = implementationSlugs
  .map((slug) => docs.find((doc) => doc.slug === slug))
  .filter(Boolean);

const quickStarts = [
  {
    title: 'AI 治理框架',
    desc: '如果你的真实问题是“如何治理 AI 而不拖慢落地”，从这里开始。',
    links: [
      { href: '/zh/learn/trust-vs-override-framework/', label: '信任与接管框架' },
      { href: '/zh/learn/board-ai-governance-briefing/', label: '董事会 AI 治理简报' },
      { href: '/zh/learn/governance-lite-implementation/', label: '治理落地指南' },
    ],
  },
  {
    title: 'AI 准备度清单',
    desc: '如果你需要先判断管理层准备度，再决定 rollout 节奏，走这条路径。',
    links: [
      { href: '/zh/ai-leadership-readiness-checklist/', label: '领导力准备度清单' },
      { href: '/zh/learn/ai-leadership-maturity-model/', label: '领导力成熟度模型' },
      { href: '/zh/learn/ai-literacy-baseline-assessment/', label: 'AI 素养基线评估' },
    ],
  },
  {
    title: '管理层 AI 运营模型',
    desc: '如果你需要的是一套管理节奏，而不是零散试点，这里最适合。',
    links: [
      { href: '/zh/learn/ai-decision-intelligence-stack-executives/', label: '决策智能栈' },
      { href: '/zh/learn/ai-signal-to-decision-operating-rhythm/', label: '信号到决策节奏' },
      { href: '/zh/learn/executive-decision-memo-template/', label: '高管决策备忘录模板' },
    ],
  },
];
---

<Layout
  title="AI治理框架、准备度清单与管理层AI运营模型 | AILD"
  description="AILD 中文知识库聚焦 AI 治理框架、AI 准备度清单、董事会监督、高管决策模板与 AI 运营模型等常青资源。"
  canonical="https://aild.org/zh/learn/"
  active="learn"
  lang="zh-CN"
>
  <section class="hero">
    <p class="eyebrow">常青资源库</p>
    <h1>围绕真实管理问题组织的 AI 领导力资源</h1>
    <p class="lead">这里是 AILD 面向搜索意图的常青内容层。适合查找 AI 治理框架、AI 准备度清单、董事会 AI 监督模型、高管决策模板与 AI 运营模型指南。</p>
    <div class="badge-row">
      <span class="badge">{docs.length} 篇常青指南</span>
      <span class="badge">治理 + 准备度 + 运营模型</span>
      <span class="badge">每周简报归档已与常青排名层分开</span>
    </div>
  </section>

  <section class="section grid-3">
    {quickStarts.map((item) => (
      <article class="panel">
        <p class="eyebrow">常见搜索意图</p>
        <h2>{item.title}</h2>
        <p>{item.desc}</p>
        <ul>
          {item.links.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </article>
    ))}
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">旗舰页面</p>
        <h2>六个应该承载主要搜索权重的核心页面</h2>
      </div>
      <p class="lead">这些页面是 AILD 最值得强化的管理层搜索资产。</p>
    </div>
    <div class="article-list">
      {flagshipDocs.map((doc) => (
        <article class="article-item">
          <p class="tag">{doc.data.tags.join(' | ')}</p>
          <h2><a href={`/zh/learn/${doc.slug}/`}>{doc.data.title}</a></h2>
          <p>{doc.data.description}</p>
          <p class="kb-meta">
            {doc.data.readingTime ? `阅读时长：${doc.data.readingTime}` : ''}{doc.data.audience ? ` | 适用：${doc.data.audience}` : ''}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">支撑层</p>
        <h2>为旗舰页面服务的实施与执行资源</h2>
      </div>
      <p class="lead">这些页面负责把框架延伸到执行节奏、实施路径和测量方法。</p>
    </div>
    <div class="article-list">
      {implementationDocs.map((doc) => (
        <article class="article-item">
          <p class="tag">{doc.data.tags.join(' | ')}</p>
          <h2><a href={`/zh/learn/${doc.slug}/`}>{doc.data.title}</a></h2>
          <p>{doc.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section panel">
    <h2>快速找到你需要的内容</h2>
    <p class="lead">支持搜索与标签筛选。每周简报已走单独的编辑归档路径。</p>
    <div class="kb-toolbar">
      <input id="kb-search" class="kb-search" type="search" placeholder="搜索常青内容（如：治理、董事会、清单、ROI）..." />
      <div class="kb-filters" id="kb-filters">
        <button class="kb-chip active" data-tag="all" type="button">全部</button>
        {tags.map((tag) => (
          <button class="kb-chip" data-tag={tag.toLowerCase()} type="button">{tag}</button>
        ))}
      </div>
      <p class="kb-count">当前显示 <span id="kb-count">{docs.length}</span> 篇</p>
    </div>
    <p class="signal-note">如果你要看持续更新的编辑产品，请转到 <a href="/zh/weekly-brief/">每周简报归档</a>。</p>
  </section>

  <section class="section article-list" id="kb-list">
    {
      docs.map((doc) => (
        <article class="article-item kb-item" data-tags={doc.data.tags.map((t) => t.toLowerCase()).join(',')}>
          <p class="tag">{doc.data.tags.join(' | ')}</p>
          <h2><a href={`/zh/learn/${doc.slug}/`}>{doc.data.title}</a></h2>
          <p>{doc.data.description}</p>
          <p class="kb-meta">
            {doc.data.readingTime ? `阅读时长：${doc.data.readingTime}` : ''}{doc.data.audience ? ` | 适用：${doc.data.audience}` : ''}
          </p>
        </article>
      ))
    }
  </section>

  <script is:inline>
    (() => {
      const search = document.getElementById('kb-search');
      const chips = Array.from(document.querySelectorAll('.kb-chip'));
      const items = Array.from(document.querySelectorAll('.kb-item'));
      const count = document.getElementById('kb-count');
      if (!search || !items.length || !count) return;

      let activeTag = 'all';

      const apply = () => {
        const q = search.value.trim().toLowerCase();
        let visible = 0;

        items.forEach((item) => {
          const text = item.textContent.toLowerCase();
          const tags = (item.getAttribute('data-tags') || '').split(',');
          const matchTag = activeTag === 'all' || tags.includes(activeTag);
          const matchQuery = !q || text.includes(q);
          const show = matchTag && matchQuery;
          item.classList.toggle('kb-hidden', !show);
          if (show) visible += 1;
        });

        count.textContent = String(visible);
      };

      chips.forEach((chip) => {
        chip.addEventListener('click', () => {
          chips.forEach((c) => c.classList.remove('active'));
          chip.classList.add('active');
          activeTag = chip.getAttribute('data-tag') || 'all';
          apply();
        });
      });

      search.addEventListener('input', apply);
      apply();
    })();
  </script>
</Layout>
