---
import Layout from '../../layouts/Layout.astro';
import LeadCaptureForm from '../../components/LeadCaptureForm.astro';
import { getCollection } from 'astro:content';

const briefs = (await getCollection('zhdocs'))
  .filter((doc) => doc.data.tags.includes('weekly-brief'))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const [latestBrief, ...archiveBriefs] = briefs;
---

<Layout
  title="AI领导力每周简报 | AILD"
  description="面向管理层的AI每周简报：本周发生了什么、为什么重要、下周该做什么。"
  canonical="https://aild.org/zh/weekly-brief/"
  active=""
  lang="zh-CN"
>
  <section class="hero home-hero weekly-brief-hero">
    <div class="home-hero-grid">
      <div>
        <p class="eyebrow">签名产品</p>
        <h1>为战略与转型负责人准备的 AI 每周简报</h1>
        <p class="lead">
          AILD 每周简报把快速变化的AI信息压缩成管理层可直接使用的结构：本周发生了什么，为什么重要，接下来7天应该采取什么动作。
        </p>
        <div class="badge-row">
          <span class="badge">本周变化</span>
          <span class="badge">管理层意义</span>
          <span class="badge">未来7天动作</span>
        </div>
        <div class="stack">
          {latestBrief && <a class="btn btn-primary" href={`/zh/learn/${latestBrief.slug}/`}>阅读最新一期</a>}
          <a class="btn btn-secondary" href="/zh/ai-leadership-readiness-checklist/">领取准备度清单</a>
        </div>
      </div>
      <LeadCaptureForm
        compact={true}
        eyebrow="加入名单"
        title="申请接收管理层简报"
        lead="如果你希望持续收到AILD的每周简报、重点更新和新的管理工具，可以在这里留下信息。"
        buttonLabel="加入简报名单"
        subject="AILD 每周简报订阅"
        nextUrl="https://aild.org/zh/brief-subscribe-success/"
        source="zh-weekly-brief-page"
        interest="AI领导力每周简报"
        lang="zh"
        proofItems={['每周更新', '管理层可用格式', '信号 -> 含义 -> 动作']}
      />
    </div>
  </section>

  <section class="section brief-signature-grid">
    <article class="panel brief-signature-card">
      <p class="eyebrow">为什么管理层会看</p>
      <h2>不是新闻汇总，而是决策输入</h2>
      <ul>
        <li>把AI新闻转换为治理、组织、流程和决策层面的含义。</li>
        <li>强调本季度该关注的问题，而不是泛泛而谈的趋势噪音。</li>
        <li>适合作为管理例会、转型复盘和董事会准备的输入材料。</li>
      </ul>
    </article>
    <article class="panel brief-signature-card">
      <p class="eyebrow">固定结构</p>
      <h2>每一期都遵守同样的编辑纪律</h2>
      <ul>
        <li><strong>本周发生了什么：</strong>管理层不该错过的外部变化。</li>
        <li><strong>这意味着什么：</strong>对治理、运营和能力建设的影响。</li>
        <li><strong>未来7天动作：</strong>本周应该推进的管理动作与判断。</li>
      </ul>
    </article>
    <article class="panel brief-signature-card">
      <p class="eyebrow">编辑承诺</p>
      <h2>这是持续维护的管理层产品，不只是栏目</h2>
      <ul>
        <li>保持稳定频率和日期可见性。</li>
        <li>直接服务于管理例会和董事会准备。</li>
        <li>与清单、案例和咨询服务配套使用。</li>
      </ul>
    </article>
  </section>

  {
    latestBrief && (
      <section class="section panel brief-latest-panel">
        <div class="section-heading">
          <div>
            <p class="eyebrow">最新一期</p>
            <h2>{latestBrief.data.title}</h2>
          </div>
          <p class="lead">{latestBrief.data.description}</p>
        </div>
        <article class="article-item brief-latest-card">
          <p class="tag">发布于 {latestBrief.data.pubDate}</p>
          <p class="kb-meta">
            {latestBrief.data.readingTime ? `阅读时长：${latestBrief.data.readingTime}` : ''}{latestBrief.data.audience ? ` | 适用：${latestBrief.data.audience}` : ''}
          </p>
          <p>最新一期简报可直接用于管理层周会、AI治理检查和本周行动优先级判断。</p>
          <a class="text-link" href={`/zh/learn/${latestBrief.slug}/`}>打开最新一期</a>
        </article>
      </section>
    )
  }

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">往期归档</p>
        <h2>最近的每周简报</h2>
      </div>
      <p class="lead">用归档来判断AILD的更新频率、编辑纪律，以及关注问题的连续性。</p>
    </div>
    <div class="article-list brief-archive editorial-archive-grid">
      {archiveBriefs.slice(0, 6).map((brief) => (
        <article class="article-item editorial-archive-card">
          <p class="tag">每周简报 | {brief.data.pubDate}</p>
          <h3><a href={`/zh/learn/${brief.slug}/`}>{brief.data.title}</a></h3>
          <p>{brief.data.description}</p>
          <p class="kb-meta">
            {brief.data.readingTime ? `阅读时长：${brief.data.readingTime}` : ''}{brief.data.audience ? ` | 适用：${brief.data.audience}` : ''}
          </p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-callout">
    <div>
      <p class="eyebrow">配套工具</p>
      <h2>把简报变成真正的管理动作</h2>
      <p>很多团队会把每周简报和AILD准备度清单、董事会简报模板或治理工作坊放在一起使用。</p>
      <div class="stack">
        <a class="btn btn-primary" href="/zh/ai-leadership-readiness-checklist/">查看准备度清单</a>
        <a class="btn btn-secondary" href="/zh/advisory/">查看服务方式</a>
      </div>
    </div>
    <LeadCaptureForm
      eyebrow="继续保持更新"
      title="申请接收后续简报"
      lead="如果你想收到每周简报和新模板更新，可以在这里留下信息。"
      buttonLabel="加入简报名单"
      subject="AILD 每周简报订阅"
      nextUrl="https://aild.org/zh/brief-subscribe-success/"
      source="zh-weekly-brief-bottom"
      interest="AI领导力每周简报"
      lang="zh"
      proofItems={['持续更新', '新工具', '只保留管理层相关内容']}
    />
  </section>
</Layout>
