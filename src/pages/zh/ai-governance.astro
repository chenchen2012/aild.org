---
import Layout from '../../layouts/Layout.astro';

const governanceAssets = [
  { title: '信任与接管框架', href: '/zh/learn/trust-vs-override-framework/', summary: '定义哪些情境可以信任 AI，哪些情境必须保留人工接管。' },
  { title: '轻量治理实施指南', href: '/zh/learn/governance-lite-implementation/', summary: '把治理原则转成管理层可运行的控制机制。' },
  { title: 'AI领导力成熟度模型', href: '/zh/learn/ai-leadership-maturity-model/', summary: '从治理成熟度角度评估准备度、责任结构和控制姿态。' },
  { title: 'AI数据隐私清单', href: '/zh/learn/ai-data-privacy-checklist/', summary: '用务实清单强化数据暴露和复核边界。' },
];
---

<Layout
  title="AI治理 | AILD"
  description="用 AILD 建立 AI 治理结构、控制点、决策权与复盘规则，在采用规模化前先把边界立清楚。"
  canonical="https://aild.org/zh/ai-governance/"
  active="ai-governance"
  lang="zh-CN"
>
  <section class="hero">
    <p class="eyebrow">AI治理</p>
    <h1>在AI使用扩散到全组织之前先建立治理</h1>
    <p class="lead">当管理层需要更明确的控制点、责任人和决策规则时，就应该从这里开始。</p>
    <div class="stack">
      <a class="btn btn-primary" href="#governance-assets">查看治理框架</a>
      <a class="btn btn-secondary" href="/zh/advisory/">申请高管简报</a>
    </div>
  </section>

  <section class="section proof-grid">
    <article class="panel">
      <p class="eyebrow">解决什么问题</p>
      <ul class="mini-list">
        <li>明确决策权</li>
        <li>建立治理边界</li>
        <li>形成复核与升级结构</li>
        <li>减少失控扩散的AI使用</li>
      </ul>
    </article>
    <article class="panel">
      <p class="eyebrow">适合谁</p>
      <ul class="mini-list">
        <li>治理负责人</li>
        <li>转型负责人</li>
        <li>COO</li>
        <li>战略负责人</li>
      </ul>
    </article>
  </section>

  <section class="section" id="governance-assets">
    <div class="section-heading">
      <div>
        <p class="eyebrow">核心框架</p>
        <h2>定义治理结构与控制姿态的关键页面</h2>
      </div>
      <p class="lead">这些页面帮助管理层明确责任、风险姿态、复核逻辑和政策边界。</p>
    </div>
    <div class="article-list">
      {governanceAssets.map((asset) => (
        <article class="article-item">
          <h2><a href={asset.href}>{asset.title}</a></h2>
          <p>{asset.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-callout">
    <div class="panel">
      <p class="eyebrow">管理层真正要回答的问题</p>
      <ul class="mini-list">
        <li>谁有权批准新的AI使用</li>
        <li>哪些情境必须人工接管</li>
        <li>什么需要记录和升级</li>
        <li>采用扩大后治理如何升级</li>
      </ul>
    </div>
    <div>
      <p class="eyebrow">下一步</p>
      <h2>如果你需要一个管理层真正能运行的治理结构</h2>
      <p>AILD 可以帮助你把治理原则落实成可执行的责任结构、复核节点和管理纪律。</p>
      <div class="stack">
        <a class="btn btn-primary" href="/zh/advisory/">讨论咨询支持</a>
      </div>
    </div>
  </section>
</Layout>
