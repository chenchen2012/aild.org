---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const docs = (await getCollection('zhdocs')).sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
const featuredDocs = docs.slice(0, 3);
---

<Layout
  title="AI领导力与发展（AILD）"
  description="AILD（AI领导力与发展）：帮助管理者构建AI时代的决策能力、增强认知与组织执行体系。"
  canonical="https://aild.org/zh/"
  active="home"
  lang="zh-CN"
>
  <section class="hero home-hero">
    <div class="home-hero-grid">
      <div>
        <p class="eyebrow">面向AI时代管理者的决策与执行系统</p>
        <h1>AI领导力与发展（AILD）</h1>
        <p class="lead">
          我们关注的不是“多生成一点内容”，而是让管理层把AI纳入真正可追责的决策系统。
          AILD帮助组织明确AI辅助边界、管理责任归属与执行复盘节奏。
        </p>
        <div class="home-proofline">
          <span>适合管理层与高管团队</span>
          <span>适合战略与运营负责人</span>
          <span>适合AI转型负责人</span>
        </div>
        <div class="stack">
          <a class="btn btn-primary" href="/zh/learn/ai-decision-intelligence-stack-executives/">先看决策智能框架</a>
          <a class="btn btn-secondary" href="/zh/playbooks/">查看执行手册</a>
        </div>
      </div>
      <aside class="signal-panel">
        <p class="eyebrow">你会得到什么</p>
        <h2>把 AI 试验转成真正的管理操作系统</h2>
        <ul class="signal-list">
          <li><strong>决策框架：</strong>明确决策权、责任人与证据门槛。</li>
          <li><strong>信任边界：</strong>定义何时由AI辅助，何时必须人工接管。</li>
          <li><strong>执行节奏：</strong>把信号、决策、行动与复盘串成每周机制。</li>
        </ul>
        <div class="signal-callout">
          <strong>推荐第一步：</strong>
          <a href="/zh/learn/ai-decision-intelligence-stack-executives/"> 先读决策智能框架</a>
        </div>
      </aside>
    </div>
    <div class="metrics home-metrics">
      <div class="metric"><strong>更快决策周期</strong><span>缩短“复盘到决策”的关键链路</span></div>
      <div class="metric"><strong>更高决策质量</strong><span>用统一框架降低判断波动</span></div>
      <div class="metric"><strong>更稳风险控制</strong><span>明确何时信任AI、何时人工接管</span></div>
    </div>
  </section>

  <section class="section">
    <div class="home-path-grid">
      <article class="home-path-card panel">
        <p class="eyebrow">如果你在定战略</p>
        <h2>先看领导决策模型</h2>
        <p>先理解决策栈、信任边界与治理逻辑，再决定工具和组织动作。</p>
        <a class="text-link" href="/zh/learn/ai-decision-intelligence-stack-executives/">阅读高管决策框架</a>
      </article>
      <article class="home-path-card panel">
        <p class="eyebrow">如果你在抓执行</p>
        <h2>先看手册和模板</h2>
        <p>优先安装会议协议、决策备忘录、节奏机制和结果衡量方法。</p>
        <a class="text-link" href="/zh/playbooks/">打开执行手册</a>
      </article>
      <article class="home-path-card panel">
        <p class="eyebrow">如果你需要说服组织</p>
        <h2>先看研究与案例</h2>
        <p>用研究依据和案例结构支持内部沟通，降低转型阻力。</p>
        <a class="text-link" href="/zh/research/">查看研究依据</a>
      </article>
    </div>
  </section>

  <section class="section home-proof">
    <article class="panel">
      <p class="eyebrow">现实落差</p>
      <h2>为什么很多AI项目看起来很忙，却很难形成战略价值</h2>
      <p>
        工具上线很快，但领导系统没有同步升级。没有决策架构，AI产出就会停留在“内容层”而不是“决策层”。
        AILD提供可落地的管理框架，把判断、治理和执行连成一个系统。
      </p>
      <div class="kpi-strip">
        <div class="kpi"><strong>第1周</strong>决策流映射 + 风险分层</div>
        <div class="kpi"><strong>第2周</strong>信任/接管规则 + 记录机制</div>
        <div class="kpi"><strong>第3-4周</strong>高管节奏 + 结果复盘</div>
      </div>
    </article>
    <article class="story-note">
      <p class="eyebrow">优秀团队的共同做法</p>
      <ul>
        <li>把“决策质量”设为AI转型核心指标</li>
        <li>区分“AI分析建议”与“管理层最终责任”</li>
        <li>建立每周决策复盘，持续校准判断标准</li>
      </ul>
      <p>可继续查看 <a href="/zh/cases/">案例</a> 与 <a href="/zh/research/">研究依据</a>。</p>
    </article>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">建议从这里开始</p>
        <h2>精选领导力指南</h2>
      </div>
      <p class="lead">
        先看最核心的三篇，再逐步进入完整知识库，建立适合管理层的AI决策与执行系统。
      </p>
    </div>
    <div class="article-list section home-featured-grid">
      {
        featuredDocs.map((doc) => (
          <article class="article-item home-featured-item">
            <p class="tag">{doc.data.tags.join(' | ')}</p>
            <h3><a href={`/zh/learn/${doc.slug}/`}>{doc.data.title}</a></h3>
            <p>{doc.data.description}</p>
            <p class="kb-meta">
              {doc.data.readingTime ? `阅读时长：${doc.data.readingTime}` : ''}{doc.data.audience ? ` | 适用：${doc.data.audience}` : ''}
            </p>
          </article>
        ))
      }
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="/zh/learn/">浏览全部中文领导力内容</a>
      <a class="btn btn-secondary" href="/">View English homepage</a>
    </div>
  </section>
</Layout>
