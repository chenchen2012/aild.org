---
import Layout from '../../layouts/Layout.astro';

const priorityPaths = [
  {
    title: '董事会准备',
    summary: '在 AI 采用扩大前，先厘清董事会真正需要看的监督问题与责任结构。',
    audience: '适合 CEO、COO、治理负责人，以及需要面向董事会汇报的运营负责人。',
    href: '/zh/board-readiness/',
    cta: '查看董事会准备路径',
  },
  {
    title: 'AI治理',
    summary: '在 AI 使用扩散前，先建立决策权、控制点和治理结构。',
    audience: '适合治理负责人、转型负责人，以及对风险与落地节奏负责的高级管理者。',
    href: '/zh/ai-governance/',
    cta: '查看治理框架',
  },
  {
    title: '90天落地',
    summary: '把零散试点转成一个有管理责任、有节奏的90天落地计划。',
    audience: '适合 COO、战略负责人和负责执行推进的转型团队。',
    href: '/zh/90-day-rollout/',
    cta: '打开90天落地计划',
  },
  {
    title: '高管汇报',
    summary: '建立高管和董事会真正能用的汇报结构，清楚呈现进展、风险和责任。',
    audience: '适合负责高管更新、董事会准备与项目复盘的团队。',
    href: '/zh/executive-reporting/',
    cta: '使用高管汇报工具',
  },
  {
    title: '运营节奏',
    summary: '建立可重复的管理层节奏，把信号、决策和跟进纳入固定运营机制。',
    audience: '适合需要把 AI 纳入日常经营节奏的管理团队。',
    href: '/zh/operating-rhythm/',
    cta: '查看运营节奏模型',
  },
];

const pressurePoints = [
  { title: '在AI使用扩散前先建立治理', summary: '先明确责任、升级规则、复核节点和边界，而不是等问题出现后再补。' },
  { title: '给董事会一个清晰的监督视角', summary: '把 AI 活动翻译成董事会真正关心的监督问题、风险视图和管理层责任。' },
  { title: '把试点升级成90天受控落地', summary: '用有顺序的落地计划替代零散实验，并把复盘节奏嵌入管理层机制。' },
  { title: '建立真正可用的管理汇报', summary: '汇报要支持决策，而不是只罗列活动。' },
  { title: '形成可重复的运营节奏', summary: '把 AI 管理变成持续运营动作，而不是一次性项目。' },
];

const flagshipAssets = [
  { title: 'AI治理框架', href: '/zh/learn/trust-vs-override-framework/', summary: '用于定义治理结构、控制点和管理责任。' },
  { title: '董事会AI治理简报', href: '/zh/learn/board-ai-governance-briefing/', summary: '用于准备董事会层面的讨论、监督与责任界面。' },
  { title: 'AI治理准备度清单', href: '/zh/ai-leadership-readiness-checklist/', summary: '用于判断治理、监督和运营系统是否真的准备好进入规模化采用。' },
  { title: '90天AI采用路线图', href: '/zh/learn/90-day-ai-adoption-roadmap/', summary: '用于组织第一个受控推进窗口。' },
  { title: '高管决策备忘录模板', href: '/zh/learn/executive-decision-memo-template/', summary: '用于统一高管复核、决策与后续跟进。' },
  { title: 'AI信号到决策运营节奏', href: '/zh/learn/ai-signal-to-decision-operating-rhythm/', summary: '用于建立可重复的管理层复盘与行动节奏。' },
];

const proofItems = [
  { title: '案例快照', summary: '用短案例展示管理团队如何处理监督、汇报与落地决策。' },
  { title: '实施模式', summary: '把治理、试点、汇报和运营复盘串成可执行模式。' },
  { title: '决策信号', summary: '帮助管理层识别 AI 何时正在从实验走向真正的受控执行。' },
];

const credibilityItems = [
  { title: '关于AILD', href: '/zh/about/', summary: '查看 AILD 面向谁、解决什么问题。' },
  { title: '编辑责任说明', href: '/zh/author/', summary: '查看网站如何被编辑、维护与判断。' },
  { title: '编辑标准', href: '/zh/editorial-standards/', summary: '查看页面如何选题、更新与维护。' },
  { title: '研究方法', href: '/zh/research/', summary: '查看框架、案例与建议背后的证据基础。' },
];
---

<Layout
  title="面向决策者的AI治理与决策支持 | AILD"
  description="AILD 帮助管理层建立 AI 治理、董事会可用的汇报结构，以及在规模化采用前必须先建立的运营纪律。"
  canonical="https://aild.org/zh/"
  active="home"
  lang="zh-CN"
  showUpdatedStamp={false}
>
  <section class="hero home-hero">
    <div class="home-hero-grid">
      <div class="home-hero-main">
        <p class="eyebrow">AILD | 面向决策者的AI治理与决策支持</p>
        <h1>服务于治理、落地与监督负责人的 AI 决策支持平台</h1>
        <p class="lead">AILD 帮助管理团队在 AI 规模化采用前，先把治理、董事会汇报结构和运营纪律建立起来。</p>
        <div class="home-hero-proofline">
          <span>适合 CEO、COO、战略与转型负责人、治理负责人，以及需要面向董事会汇报的运营角色</span>
        </div>
        <div class="stack">
          <a class="btn btn-primary" href="#priority-paths">从你的优先路径开始</a>
          <a class="btn btn-secondary" href="/zh/advisory/">申请高管简报</a>
        </div>
      </div>
      <div class="panel home-hero-aside">
        <p class="eyebrow">适合从这里开始的情况</p>
        <div class="snapshot-item">
          <strong>治理</strong>
          <span>在 AI 使用扩散前先把控制点和责任结构立起来。</span>
        </div>
        <div class="snapshot-item">
          <strong>汇报</strong>
          <span>准备董事会真正能用的监督、责任与复盘视图。</span>
        </div>
        <div class="snapshot-item">
          <strong>运营节奏</strong>
          <span>把试点升级成受控的管理层节奏和跟进机制。</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="priority-paths">
    <div class="section-heading">
      <div>
        <p class="eyebrow">优先路径</p>
        <h2>先进入你当前最需要解决的业务问题</h2>
      </div>
      <p class="lead">AILD 按管理层真实会面对的决策问题来组织，而不是按内容类型来组织。</p>
    </div>
    <div class="proof-grid">
      {priorityPaths.map((path) => (
        <article class="panel home-path-card">
          <h2>{path.title}</h2>
          <p>{path.summary}</p>
          <p class="kb-meta">{path.audience}</p>
          <a class="text-link" href={path.href}>{path.cta}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">管理压力</p>
        <h2>AI规模化前，管理层必须先做对的几件事</h2>
      </div>
      <p class="lead">很多组织不是没有 AI 动作，而是治理、汇报和运营纪律没有跟上采用速度。</p>
    </div>
    <div class="urgency-strip">
      {pressurePoints.map((item) => (
        <article class="urgency-card">
          <strong>{item.title}</strong>
          <span>{item.summary}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">旗舰资产</p>
        <h2>先看最值得管理层使用的核心框架与工具</h2>
      </div>
      <p class="lead">这些是最适合用于治理、监督、落地与运营节奏的核心页面。</p>
    </div>
    <div class="article-list home-featured-grid">
      {flagshipAssets.map((asset) => (
        <article class="article-item home-featured-item">
          <h3><a href={asset.href}>{asset.title}</a></h3>
          <p>{asset.summary}</p>
        </article>
      ))}
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="#priority-paths">查看高管优先路径</a>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">实践证明</p>
        <h2>这类工作在真实组织里是什么样子</h2>
      </div>
      <p class="lead">AILD 不只提供框架，也把管理建议连接到实施模式、汇报结构和真实领导场景。</p>
    </div>
    <div class="proof-grid">
      {proofItems.map((item) => (
        <article class="panel">
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="/zh/cases/">查看高管案例</a>
    </div>
  </section>

  <section class="section split-callout">
    <div>
      <p class="eyebrow">高管咨询</p>
      <h2>把这些内容带入真实领导场景</h2>
      <p>AILD 可以作为管理层决策支持层、工作坊输入层，或治理设计的起点。</p>
      <p class="signal-note">适合需要就治理、汇报、落地优先级和运营纪律做更快对齐的管理团队。</p>
      <div class="stack">
        <a class="btn btn-primary" href="/zh/advisory/">讨论咨询支持</a>
      </div>
    </div>
    <div class="panel">
      <p class="eyebrow">适用场景</p>
      <ul class="mini-list">
        <li>正在准备董事会汇报的管理团队</li>
        <li>准备从试点进入正式落地阶段的转型团队</li>
        <li>正在强化治理和汇报责任的组织</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">可信度</p>
        <h2>为什么AILD值得信任</h2>
      </div>
      <p class="lead">AILD 通过明确的编辑标准、可见的责任人和有证据基础的框架来支持管理判断。</p>
    </div>
    <div class="proof-grid">
      {credibilityItems.map((item) => (
        <article class="panel">
          <h3><a href={item.href}>{item.title}</a></h3>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-callout home-cta-band">
    <div>
      <p class="eyebrow">每周简报</p>
      <h2>获取面向高级AI决策的每周简报</h2>
      <p>每周简报用于帮助管理层跟进 AI 变化中的关键信号、治理影响和运营问题。</p>
      <div class="stack">
        <a class="btn btn-primary" href="/zh/weekly-brief/">订阅每周简报</a>
      </div>
    </div>
    <div class="panel home-brief-panel">
      <p class="eyebrow">你会看到什么</p>
      <ul class="mini-list">
        <li>重要AI变化的高管摘要</li>
        <li>值得关注的董事会与治理影响</li>
        <li>影响落地节奏的运营问题</li>
      </ul>
    </div>
  </section>
</Layout>
