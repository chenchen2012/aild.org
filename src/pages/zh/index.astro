---
import Layout from '../../layouts/Layout.astro';
import LeadCaptureForm from '../../components/LeadCaptureForm.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('zhdocs');
const weeklyBriefs = docs
  .filter((doc) => doc.data.tags.includes('weekly-brief'))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 2);
const cornerstonePages = [
  {
    label: '框架',
    title: '面向高管的 AI 决策智能栈',
    href: '/zh/learn/ai-decision-intelligence-stack-executives/',
    summary: 'AILD 的核心管理模型：先建立决策结构，再扩展工具。',
  },
  {
    label: '治理',
    title: '信任与接管框架',
    href: '/zh/learn/trust-vs-override-framework/',
    summary: '明确哪些情境可以信任 AI，哪些情境必须人工接管。',
  },
  {
    label: '能力',
    title: 'AI 领导力成熟度模型',
    href: '/zh/learn/ai-leadership-maturity-model/',
    summary: '用于评估组织在领导层、治理和执行节奏上的准备度。',
  },
  {
    label: '签名产品',
    title: 'AI 领导力每周简报',
    href: '/zh/weekly-brief/',
    summary: '固定管理层格式：发生了什么、为什么重要、下周做什么。',
  },
  {
    label: '旗舰工具',
    title: 'AI 领导力准备度清单',
    href: '/zh/ai-leadership-readiness-checklist/',
    summary: '适合董事会准备、转型推进和首个 90 天行动设计。',
  },
];
---

<Layout
  title="AI领导力、AI治理与管理层决策框架 | AILD"
  description="面向管理层的AI领导力框架、AI治理方法与高管决策体系。帮助组织建立AI辅助决策、信任边界与执行节奏。"
  canonical="https://aild.org/zh/"
  active="home"
  lang="zh-CN"
>
  <section class="hero home-hero">
    <div class="home-hero-grid">
      <div>
        <p class="eyebrow">面向战略负责人和转型负责人的 AI 管理系统</p>
        <h1>先让 AI 在管理层层面变得可信，再谈规模化</h1>
        <p class="lead">
          AILD现在更明确地服务于战略负责人、转型负责人和非技术高管团队。重点不是“工具多先进”，而是帮助组织建立AI决策框架、治理边界、执行节奏和真正可复盘的管理系统。
        </p>
        <div class="home-proofline">
          <span>聚焦战略与转型负责人</span>
          <span>{docs.length} 篇实用指南与管理工具</span>
          <span>每周简报 + 模板 + 案例 + 研究</span>
        </div>
        <div class="stack">
          <a class="btn btn-primary" href="/zh/ai-leadership-readiness-checklist/">获取准备度清单</a>
          <a class="btn btn-secondary" href="/zh/weekly-brief/">阅读每周简报</a>
        </div>
        <p class="signal-note">如果你需要一份诊断工具，就先看准备度清单；如果你需要持续的管理层信号输入，就先看每周简报。</p>
      </div>
      <LeadCaptureForm
        compact={true}
        eyebrow="加入管理层简报"
        title="获取 AILD 每周简报和旗舰工具"
        lead="如果你希望持续获得管理层简报、准备度工具和新的治理资源，可以在这里留下信息。"
        buttonLabel="加入名单"
        subject="AILD 中文首页简报申请"
        nextUrl="https://aild.org/zh/brief-subscribe-success/"
        source="zh-homepage-hero"
        interest="AILD 每周简报与管理工具"
        lang="zh"
        proofItems={['37+ 指南', '每周管理层简报', '董事会与转型场景']}
      />
    </div>
    <div class="metrics home-metrics">
      <div class="metric"><strong>37+</strong><span>篇实用指南、模板、案例和研究内容</span></div>
      <div class="metric"><strong>每周更新</strong><span>管理层可直接使用的编辑简报</span></div>
      <div class="metric"><strong>3类核心产品</strong><span>简报、工具、咨询服务共同构成品牌入口</span></div>
    </div>
  </section>

  <section class="section trust-grid">
    <article class="panel">
      <p class="eyebrow">服务对象</p>
      <h2>这一阶段的核心人群</h2>
      <p>AILD 当前优先服务战略负责人、转型负责人，以及需要为AI rollout 负责的非技术高管团队。</p>
    </article>
    <article class="panel">
      <p class="eyebrow">解决什么问题</p>
      <h2>AI 项目通常卡住的地方</h2>
      <p>试点分散、决策权不清、治理边界模糊、ROI无法证明、董事会信心不足、动作很多但管理系统很弱。</p>
    </article>
    <article class="panel">
      <p class="eyebrow">为什么可信</p>
      <h2>不是空泛观点，而是有结构的产品层</h2>
      <p>AILD 现在同时提供知识库、每周简报、案例结构、管理模板和可落地的咨询形式，形成更完整的信任层。</p>
    </article>
  </section>

  <section class="section panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">为什么是现在</p>
        <h2>高管没有“以后再说”的空间了</h2>
      </div>
      <p class="lead">真正的问题不是 AI 会不会继续发展，而是管理层准备度是否能跟上采用速度。</p>
    </div>
    <div class="urgency-strip">
      <article class="urgency-card">
        <strong>治理风险</strong>
        <span>AI 使用先扩散，责任和复核机制却没有同步建立。</span>
      </article>
      <article class="urgency-card">
        <strong>ROI 流失</strong>
        <span>组织自动化了活动，却没有提升决策质量和执行效率。</span>
      </article>
      <article class="urgency-card">
        <strong>错误 rollout 风险</strong>
        <span>在没有准备好管理系统前就扩大工具部署。</span>
      </article>
      <article class="urgency-card">
        <strong>董事会压力</strong>
        <span>随着AI暴露面扩大，治理问责也会更快到来。</span>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">按角色开始</p>
        <h2>直接进入与你职责匹配的路径</h2>
      </div>
      <p class="lead">一个忙碌的管理者不应该先研究网站结构，而应该先找到自己的入口。</p>
    </div>
    <div class="role-journey">
      <article class="home-path-card panel">
        <p class="eyebrow">如果你是 CEO / 总经理</p>
        <h2>先看领导模型与董事会叙事</h2>
        <p>先厘清AI在哪些地方创造价值、哪些地方需要监督、哪些决策必须保留人为判断。</p>
        <a class="text-link" href="/zh/learn/board-ai-governance-briefing/">打开董事会路径</a>
      </article>
      <article class="home-path-card panel">
        <p class="eyebrow">如果你负责转型</p>
        <h2>先看准备度、节奏机制和手册</h2>
        <p>用准备度清单、执行手册和模板，把AI活动升级成真正的管理操作系统。</p>
        <a class="text-link" href="/zh/ai-leadership-readiness-checklist/">打开转型路径</a>
      </article>
      <article class="home-path-card panel">
        <p class="eyebrow">如果你负责治理或风险</p>
        <h2>先看信任边界、案例和研究依据</h2>
        <p>用治理框架、案例结构和证据库把AI采用做得更稳，而不是一味压制。</p>
        <a class="text-link" href="/zh/cases/">查看治理案例</a>
      </article>
    </div>
  </section>

  <section class="section split-callout">
    <div>
      <p class="eyebrow">签名产品</p>
      <h2>把 AI 每周简报变成品牌核心资产</h2>
      <p>AILD 的每周简报正在成为品牌的固定入口：本周发生了什么，为什么重要，下周该采取什么动作。</p>
      <div class="stack">
        <a class="btn btn-primary" href="/zh/weekly-brief/">打开每周简报</a>
        <a class="btn btn-secondary" href="/zh/advisory/">查看工作坊与咨询形式</a>
      </div>
    </div>
    <div class="article-list brief-preview-list">
      {weeklyBriefs.map((brief) => (
        <article class="article-item">
          <p class="tag">每周简报 | {brief.data.pubDate}</p>
          <h3><a href={`/zh/learn/${brief.slug}/`}>{brief.data.title}</a></h3>
          <p>{brief.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-callout">
    <div>
      <p class="eyebrow">旗舰资源</p>
      <h2>先给管理层一个可用的工具，而不是再多一篇文章</h2>
      <p>AILD 已经把准备度评估内容打包成一份管理层可直接使用的清单，可用于周会、转型评估和董事会准备。</p>
      <div class="stack">
        <a class="btn btn-primary" href="/zh/ai-leadership-readiness-checklist/">打开准备度清单页</a>
        <a class="btn btn-secondary" href="/downloads/ai-leadership-readiness-checklist-zh.html" download>预览可打印版本</a>
      </div>
    </div>
    <LeadCaptureForm
      eyebrow="获取清单"
      title="申请旗舰管理工具"
      lead="这是最快把 AILD 带入真实管理场景的方式。"
      buttonLabel="获取清单"
      subject="AILD 中文首页清单申请"
      nextUrl="https://aild.org/zh/checklist-success/"
      source="zh-homepage-checklist"
      interest="AI领导力准备度清单"
      lang="zh"
      proofItems={['董事会问题', '90天行动计划', '可打印格式']}
    />
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">信息架构</p>
        <h2>AILD 的每个栏目都应该有明确分工</h2>
      </div>
      <p class="lead">第一次访问的人应该马上知道：哪里看概念，哪里看手册，哪里拿模板，哪里看证明，哪里看依据。</p>
    </div>
    <div class="format-grid">
      <article class="panel">
        <p class="eyebrow">知识库</p>
        <h2>概念与模型</h2>
        <p>适合先理解AI领导力、治理逻辑和管理层决策框架。</p>
      </article>
      <article class="panel">
        <p class="eyebrow">手册</p>
        <h2>一步一步的执行路径</h2>
        <p>适合需要实施顺序、会议节奏和推进路径的团队。</p>
      </article>
      <article class="panel">
        <p class="eyebrow">模板</p>
        <h2>可直接拿来改的文档</h2>
        <p>适合需要决策备忘录、日志、看板和会议结构的团队。</p>
      </article>
      <article class="panel">
        <p class="eyebrow">案例</p>
        <h2>实施证明</h2>
        <p>适合展示问题、治理动作、结果和教训，支持内部说服。</p>
      </article>
      <article class="panel">
        <p class="eyebrow">研究</p>
        <h2>证据底座</h2>
        <p>适合把外部研究、标准和领导层决策连接起来。</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">基石页面</p>
        <h2>定义 AILD 品牌的 5 个核心入口</h2>
      </div>
      <p class="lead">
        先读这 5 个标准入口，再进入完整知识库，构建适合管理层的 AI 决策、治理与执行系统。
      </p>
    </div>
    <div class="article-list section home-featured-grid">
      {
        cornerstonePages.map((page) => (
          <article class="article-item home-featured-item">
            <p class="tag">{page.label}</p>
            <h3><a href={page.href}>{page.title}</a></h3>
            <p>{page.summary}</p>
          </article>
        ))
      }
    </div>
    <div class="stack">
      <a class="btn btn-primary" href="/zh/learn/">浏览全部中文领导力内容</a>
      <a class="btn btn-secondary" href="/zh/advisory/">查看服务页面</a>
    </div>
  </section>

  <section class="section split-callout home-cta-band">
    <div>
      <p class="eyebrow">保持更新</p>
      <h2>获取每周简报、旗舰工具和新的AILD更新</h2>
      <p>中文首页现在更明确地承担回访入口和订阅入口的角色，而不只是内容目录。</p>
    </div>
    <LeadCaptureForm
      eyebrow="底部转化入口"
      title="加入 AILD 管理层名单"
      lead="申请接收每周简报和后续管理工具。"
      buttonLabel="加入名单"
      subject="AILD 中文首页底部申请"
      nextUrl="https://aild.org/zh/brief-subscribe-success/"
      source="zh-homepage-bottom"
      interest="AILD 每周简报与管理工具"
      lang="zh"
      proofItems={['每周简报', '新工具更新', '只保留管理层相关内容']}
    />
  </section>
</Layout>
