---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact request received | AILD"
  description="Your message has been sent to AILD."
  canonical="https://aild.org/contact-success/"
  active="contact"
  robots="noindex,follow"
>
  <section class="hero">
    <p class="eyebrow">Thank you</p>
    <h1>Your message is on its way.</h1>
    <p class="lead">We received your inquiry and will review it shortly. If your request is urgent, email chenchen2012@hotmail.com directly.</p>
    <div class="stack">
      <a class="btn btn-primary" href="/contact/">Send another message</a>
      <a class="btn btn-secondary" href="/learn/">Browse the knowledge library</a>
    </div>
  </section>
</Layout>
