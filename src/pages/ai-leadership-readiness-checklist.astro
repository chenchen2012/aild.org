---
import Layout from '../layouts/Layout.astro';
import LeadCaptureForm from '../components/LeadCaptureForm.astro';

const readinessSections = [
  {
    title: 'Leadership readiness',
    text: 'Check whether ownership, executive sponsorship, and governance decisions are explicit before rollout expands.',
  },
  {
    title: 'Policy and control readiness',
    text: 'Assess approved tools, data boundaries, review triggers, and escalation paths before teams normalize unsafe workarounds.',
  },
  {
    title: 'Reporting and rollout readiness',
    text: 'Confirm there is a 90-day plan, metric baseline, and board-ready reporting rhythm instead of isolated pilots.',
  },
];

const supportLinks = [
  { href: '/learn/ai-literacy-baseline-assessment/', title: 'AI Readiness Baseline Assessment for Teams', summary: 'Use this assessment when you need a deeper scorecard behind the checklist.' },
  { href: '/learn/ai-leadership-maturity-model/', title: 'AI Governance Maturity Model for Leadership Teams', summary: 'See what readiness looks like across stages of governance and execution maturity.' },
  { href: '/board-readiness/', title: 'Board AI Governance and Oversight', summary: 'Use this when readiness questions now need board-level framing and oversight.' },
  { href: '/90-day-rollout/', title: '90-Day AI Rollout Plan for Executive Teams', summary: 'Use this when the checklist is complete and leadership needs a controlled execution path.' },
];
---

<Layout
  title="AI Readiness Checklist for Leaders | AILD"
  description="Use this executive AI readiness checklist to assess governance, decision rights, board oversight, metrics, and rollout readiness before AI adoption scales."
  canonical="https://aild.org/ai-leadership-readiness-checklist/"
  active=""
>
  <section class="hero home-hero">
    <div class="home-hero-grid">
      <div>
        <p class="eyebrow">Flagship executive tool</p>
        <h1>AI readiness checklist for leaders</h1>
        <p class="lead">
          An AI readiness checklist helps executive teams assess whether governance, board oversight, policy boundaries,
          reporting, and rollout ownership are ready before AI adoption scales across the organization. Use this page
          when the real question is not whether AI is interesting, but whether leadership is actually prepared to scale
          it with control.
        </p>
        <div class="badge-row">
          <span class="badge">Core topic: AI readiness checklist</span>
          <span class="badge">Governance + board oversight</span>
          <span class="badge">90-day rollout readiness</span>
        </div>
        <div class="stack">
          <a class="btn btn-secondary" href="/downloads/ai-leadership-readiness-checklist.html" download>Preview the checklist</a>
          <a class="btn btn-primary" href="#checklist-form">Request the download</a>
        </div>
      </div>
      <LeadCaptureForm
        eyebrow="Get the asset"
        title="Request the printable checklist"
        lead="Leave your details and we will send you to the download page immediately."
        buttonLabel="Get the checklist"
        subject="AILD checklist request"
        nextUrl="https://aild.org/checklist-success/"
        source="checklist-page"
        interest="AI leadership readiness checklist"
        proofItems={['Board prep', 'Executive workshops', 'Quarterly readiness reviews']}
      />
    </div>
  </section>

  <section class="section proof-grid">
    <article class="panel">
      <p class="eyebrow">What it covers</p>
      <h2>Six questions leadership teams should answer before scaling AI</h2>
      <ul>
        <li>Do we know which decisions should be AI-assisted and which should not?</li>
        <li>Are governance roles, escalation paths, and override rules explicit?</li>
        <li>Can we show baseline metrics, not just enthusiasm and pilots?</li>
        <li>Do leaders know what this quarter's AI priorities actually are?</li>
        <li>Are board and executive reviews looking at value and control together?</li>
        <li>Is there a 30-90 day operating rhythm, not just isolated experiments?</li>
      </ul>
    </article>
    <article class="panel">
      <p class="eyebrow">Best use cases</p>
      <h2>Use it before a workshop, steering meeting, or board update</h2>
      <ul>
        <li>Transformation office readiness reviews</li>
        <li>Executive team strategy offsites</li>
        <li>Board AI readiness and governance sessions</li>
        <li>Early-stage advisory diagnostics for a business unit</li>
      </ul>
    </article>
  </section>

  <section class="section panel">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Checklist structure</p>
        <h2>What a practical AI readiness assessment should cover</h2>
      </div>
      <p class="lead">The highest-value readiness checks are concrete. They tell leadership whether the next quarter of rollout is likely to hold together operationally.</p>
    </div>
    <div class="pillar-outline">
      {readinessSections.map((item) => (
        <article class="card">
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section split-callout">
    <div>
      <p class="eyebrow">What you download</p>
      <h2>A concise executive tool, not a generic worksheet</h2>
      <p>
        The checklist combines a leadership scorecard, risk prompts, board questions, and a 90-day action plan. It is
        built from AILD's readiness assessment, governance brief, and operating model guidance.
      </p>
      <div class="stack">
        <a class="btn btn-primary" href="/learn/ai-literacy-baseline-assessment/">Read the baseline assessment guide</a>
        <a class="btn btn-secondary" href="/learn/board-ai-governance-briefing/">Open the board briefing framework</a>
      </div>
    </div>
    <div class="panel">
      <p class="eyebrow">Core keyword cluster</p>
      <ul>
        <li>AI readiness checklist</li>
        <li>AI readiness assessment</li>
        <li>AI governance readiness</li>
        <li>Leadership readiness for AI rollout</li>
        <li>Reporting readiness and board oversight</li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Supporting pages</p>
        <h2>Use these pages when you need a deeper readiness assessment or next-step plan</h2>
      </div>
      <p class="lead">This keeps the checklist page useful for search while giving executive teams a clear path into supporting evidence and implementation assets.</p>
    </div>
    <div class="pillar-path-grid">
      {supportLinks.map((item) => (
        <article class="pillar-link-card">
          <strong><a href={item.href}>{item.title}</a></strong>
          <p>{item.summary}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section panel" id="checklist-form">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Request access</p>
        <h2>Download the checklist and use it in your next leadership or board-prep review</h2>
      </div>
      <p class="lead">If you are evaluating AI readiness this quarter, this is the fastest AILD asset to start with.</p>
    </div>
    <LeadCaptureForm
      title="Get the AI leadership readiness checklist"
      lead="This request goes to the AILD inbox and redirects you straight to the download page."
      buttonLabel="Get the checklist"
      subject="AILD checklist request"
      nextUrl="https://aild.org/checklist-success/"
      source="checklist-bottom"
      interest="AI leadership readiness checklist"
      note="After submission you will land on the AILD download page with the printable asset."
      proofItems={['Printable asset', 'Immediate access', 'Executive-use format']}
    />
  </section>
</Layout>
