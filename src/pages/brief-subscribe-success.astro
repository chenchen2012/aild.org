---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Weekly Brief Request Received | AILD"
  description="AILD has received your weekly brief request."
  canonical="https://aild.org/brief-subscribe-success/"
  active=""
  robots="noindex,follow"
>
  <section class="hero">
    <p class="eyebrow">Request received</p>
    <h1>You are on the Weekly Brief request list</h1>
    <p class="lead">Use the links below while the AILD team reviews new brief requests and resource follow-up.</p>
    <div class="stack">
      <a class="btn btn-primary" href="/weekly-brief/">Back to the Weekly Brief</a>
      <a class="btn btn-secondary" href="/ai-leadership-readiness-checklist/">Get the checklist</a>
    </div>
  </section>
</Layout>
